---
// MRT Map — Mini Metro × Taipei Metro
// One bold line, 7 square stations, rectangle train with GSAP MotionPath
---

<canvas id="rain-canvas" class="fixed inset-0 pointer-events-none z-[1]"></canvas>

<div class="w-full h-screen relative z-[2] overflow-hidden" id="mrt-container">
  <div id="mrt-pan-wrapper" class="w-full h-full flex items-center justify-center md:pointer-events-none">
    <svg
      id="mrt-svg"
      viewBox="-20 0 1440 900"
      class="w-[280%] md:w-full max-w-[1400px] h-auto select-none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid meet"
    >
      <!-- Bold main line -->
      <path id="mrt-track"
        d="M 100,450 L 300,450 L 380,350 L 580,350 L 660,450 L 860,450 L 940,350 L 1100,350 L 1180,450 L 1340,450"
        fill="none" stroke="#e0e0e0" stroke-width="16" opacity="0.35"
        stroke-linecap="round" stroke-linejoin="round" />

      <!-- 7 square stations — all same size, evenly spread -->
      <!-- S1: terminal left -->
      <rect x="93" y="443" width="14" height="14" fill="#0a0a0a" stroke="#e0e0e0" stroke-width="2.5" opacity="0.45" />

      <!-- S2: 商店 (Store) — clickable -->
      <g class="mrt-station" data-clickable>
        <a href="https://shop.wild-flower.co" target="_blank" rel="noopener">
          <rect x="373" y="343" width="14" height="14" fill="#0a0a0a" stroke="#e0e0e0" stroke-width="2.5" opacity="0.65" />
          <text x="380" y="330" text-anchor="middle" fill="#e0e0e0"
            font-family="'Noto Sans TC', sans-serif" font-size="13" font-weight="700"
            letter-spacing="0.12em" opacity="0.6">商店</text>
        </a>
      </g>

      <!-- S3: filler -->
      <rect x="573" y="343" width="14" height="14" fill="#0a0a0a" stroke="#e0e0e0" stroke-width="2.5" opacity="0.45" />

      <!-- S4: 成員 (Artists) — clickable, center hub -->
      <g class="mrt-station" data-clickable>
        <a href="/artists">
          <rect x="653" y="443" width="14" height="14" fill="#0a0a0a" stroke="#e0e0e0" stroke-width="2.5" opacity="0.65" />
          <text x="660" y="433" text-anchor="middle" fill="#e0e0e0"
            font-family="'Noto Sans TC', sans-serif" font-size="13" font-weight="700"
            letter-spacing="0.12em" opacity="0.6">成員</text>
        </a>
      </g>

      <!-- S5: 專案 (Projects) — clickable -->
      <g class="mrt-station" data-clickable>
        <a href="/projects">
          <rect x="933" y="343" width="14" height="14" fill="#0a0a0a" stroke="#e0e0e0" stroke-width="2.5" opacity="0.65" />
          <text x="940" y="330" text-anchor="middle" fill="#e0e0e0"
            font-family="'Noto Sans TC', sans-serif" font-size="13" font-weight="700"
            letter-spacing="0.12em" opacity="0.6">專案</text>
        </a>
      </g>

      <!-- S6: 社群 (Social/IG) — clickable -->
      <g class="mrt-station" data-clickable>
        <a href="https://instagram.com/wildflower" target="_blank" rel="noopener">
          <rect x="1173" y="443" width="14" height="14" fill="#0a0a0a" stroke="#e0e0e0" stroke-width="2.5" opacity="0.65" />
          <text x="1180" y="433" text-anchor="middle" fill="#e0e0e0"
            font-family="'Noto Sans TC', sans-serif" font-size="13" font-weight="700"
            letter-spacing="0.12em" opacity="0.6">社群</text>
        </a>
      </g>

      <!-- S7: terminal right -->
      <rect x="1333" y="443" width="14" height="14" fill="#0a0a0a" stroke="#e0e0e0" stroke-width="2.5" opacity="0.45" />

      <!-- Train — simple white rectangle -->
      <rect id="mrt-train" x="-18" y="-5" width="36" height="10" rx="2" fill="#e0e0e0" opacity="0.8" />
    </svg>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';
  gsap.registerPlugin(MotionPathPlugin);

  document.addEventListener('astro:page-load', () => {
    // ── Rain (subtle) ──
    const canvas = document.getElementById('rain-canvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d')!;
      let aId: number;
      function resize() { canvas.width = innerWidth; canvas.height = innerHeight; }
      resize(); addEventListener('resize', resize);
      const drops: { x: number; y: number; speed: number; len: number; opacity: number }[] = [];
      for (let i = 0; i < Math.floor(innerWidth / 12); i++) {
        drops.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          speed: 1 + Math.random() * 2,
          len: 6 + Math.random() * 12,
          opacity: 0.015 + Math.random() * 0.025,
        });
      }
      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (const d of drops) {
          ctx.beginPath();
          ctx.moveTo(d.x, d.y);
          ctx.lineTo(d.x + 0.3, d.y + d.len);
          ctx.strokeStyle = `rgba(240,240,240,${d.opacity})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
          d.y += d.speed;
          if (d.y > canvas.height) { d.y = -d.len; d.x = Math.random() * canvas.width; }
        }
        aId = requestAnimationFrame(draw);
      }
      draw();
      document.addEventListener('astro:before-swap', () => cancelAnimationFrame(aId), { once: true });
    }

    // ── Mobile touch-pan ──
    if (innerWidth < 768) {
      const wrapper = document.getElementById('mrt-pan-wrapper');
      const svg = document.getElementById('mrt-svg');
      if (wrapper && svg) {
        wrapper.style.pointerEvents = 'auto';
        wrapper.style.touchAction = 'none';
        wrapper.style.display = 'block';
        wrapper.style.position = 'relative';
        let px = -(svg.clientWidth - innerWidth) / 2;
        let py = -(svg.clientHeight - innerHeight) / 2;
        let sx = 0, sy = 0, spx = 0, spy = 0;
        const clamp = () => {
          px = Math.max(-(svg.clientWidth - innerWidth), Math.min(0, px));
          py = Math.max(-(svg.clientHeight - innerHeight), Math.min(0, py));
        };
        const apply = () => { svg.style.transform = `translate(${px}px,${py}px)`; };
        clamp(); apply();
        wrapper.addEventListener('touchstart', e => {
          sx = e.touches[0].clientX; sy = e.touches[0].clientY; spx = px; spy = py;
        }, { passive: true });
        wrapper.addEventListener('touchmove', e => {
          px = spx + (e.touches[0].clientX - sx);
          py = spy + (e.touches[0].clientY - sy);
          clamp(); apply();
        }, { passive: true });
      }
    }

    // ── Train — GSAP MotionPath with heavy feel ──
    const train = document.getElementById('mrt-train');
    if (!train || !document.querySelector('#mrt-track')) return;

    // 7 station progress values along the path
    // Path: 100→300(200) 300→380(113) 380→580(200) 580→660(113) 660→860(200) 860→940(113) 940→1100(160) 1100→1180(113) 1180→1340(160)
    // Total ≈ 1372
    // S1=0, S2=0.228, S3=0.374, S4=0.456, S5=0.602, S6=0.822, S7=1.0
    const stops = [0, 0.228, 0.374, 0.456, 0.602, 0.822, 1.0];
    // Hub stations: S2(商店)=1, S4(成員)=3, S5(專案)=4, S6(社群)=5
    const hubs = new Set([1, 3, 4, 5]);
    let cur = 0;

    function nextStop() {
      const next = (cur + 1) % stops.length;
      if (next === 0) {
        // Reached end → fade out, teleport to start, fade in
        gsap.to(train, { duration: 0.6, opacity: 0, ease: 'power1.in', onComplete: () => {
          gsap.set(train, {
            motionPath: { path: '#mrt-track', align: '#mrt-track', alignOrigin: [0.5, 0.5], autoRotate: true, start: 0, end: 0 },
          });
          gsap.to(train, { duration: 0.5, opacity: 0.8, ease: 'power1.out', onComplete: () => {
            cur = 0;
            setTimeout(nextStop, 2000);
          }});
        }});
        return;
      }

      const dist = Math.abs(stops[next] - stops[cur]);
      // Heavier feel: longer duration, slower ease
      gsap.to(train, {
        duration: dist * 8,
        motionPath: {
          path: '#mrt-track',
          align: '#mrt-track',
          alignOrigin: [0.5, 0.5],
          autoRotate: true,
          start: stops[cur],
          end: stops[next],
        },
        ease: 'power2.inOut',
        onComplete: () => {
          cur = next;
          if (hubs.has(next)) {
            // Hub station: subtle bounce on arrival (heavy train braking)
            gsap.fromTo(train,
              { x: '+=2' },
              { x: '-=2', duration: 0.3, ease: 'elastic.out(1.0, 0.4)', onComplete: () => {
                if ((window as any).playBlip) (window as any).playBlip();
                setTimeout(nextStop, 2200 + Math.random() * 800);
              }}
            );
          } else {
            // Regular station: brief pause, no bounce
            setTimeout(nextStop, 900 + Math.random() * 400);
          }
        },
      });
    }

    // Place train at start
    gsap.set(train, {
      motionPath: { path: '#mrt-track', align: '#mrt-track', alignOrigin: [0.5, 0.5], autoRotate: true, start: 0, end: 0 },
    });
    setTimeout(nextStop, 1500);

    // Hover blip on clickable stations
    document.querySelectorAll('.mrt-station').forEach(el => {
      el.addEventListener('mouseenter', () => { if ((window as any).playBlip) (window as any).playBlip(); });
    });
  });
</script>
