---
// MRT Map — Mini Metro × WILDFLOWER
// 2 lines (orange + blue), 5 stations, large squares, high contrast
// Trains: decelerate → dwell 1.2s → accelerate (GSAP MotionPath)
// Passengers: spawn → queue → board → ride → disembark
---

<div class="w-full h-screen relative overflow-hidden" id="mrt-container">
  <svg
    id="mrt-svg"
    viewBox="0 0 1200 700"
    class="w-full h-full select-none"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid meet"
  >
    <!-- ═══ TRACKS (12px, high contrast, simple readable layout) ═══ -->

    <!-- Orange Line (horizontal): STORE → ARTISTS → PROJECTS (straight with one bend) -->
    <path id="track-orange"
      d="M 150,350 L 400,350 L 600,350 L 800,350 L 1050,350"
      fill="none" stroke="#E8753D" stroke-width="12" opacity="0.45"
      stroke-linecap="round" stroke-linejoin="round"/>

    <!-- Blue Line (vertical/diagonal): SOCIALS → ARTISTS → LIVE -->
    <path id="track-blue"
      d="M 600,120 L 600,220 L 600,350 L 600,480 L 600,600"
      fill="none" stroke="#4A90D9" stroke-width="12" opacity="0.45"
      stroke-linecap="round" stroke-linejoin="round"/>

    <!-- ═══ STATIONS (28×28 squares, very clickable, high contrast) ═══ -->

    <!-- STORE — Orange Line left terminus -->
    <g class="mrt-station" data-station="store" data-href="https://shop.wild-flower.co" data-external="true">
      <rect class="station-hit" x="122" y="322" width="56" height="56" fill="transparent" stroke="none"/>
      <rect class="station-square" x="136" y="336" width="28" height="28"
        fill="#09090b" stroke="#E8753D" stroke-width="2.5" opacity="0.55"/>
      <text class="station-label" x="150" y="326" text-anchor="middle"
        fill="#E8E4DE" font-family="'IBM Plex Mono',monospace" font-size="14" font-weight="600"
        letter-spacing="0.12em" opacity="0">STORE</text>
    </g>

    <!-- ARTISTS — Orange ∩ Blue transfer (center hub) -->
    <g class="mrt-station" data-station="artists" data-href="/artists">
      <rect class="station-hit" x="572" y="322" width="56" height="56" fill="transparent" stroke="none"/>
      <rect class="station-square" x="586" y="336" width="28" height="28"
        fill="#09090b" stroke="#E8E4DE" stroke-width="2.5" opacity="0.55"/>
      <text class="station-label" x="600" y="326" text-anchor="middle"
        fill="#E8E4DE" font-family="'IBM Plex Mono',monospace" font-size="14" font-weight="600"
        letter-spacing="0.12em" opacity="0">ARTISTS</text>
    </g>

    <!-- PROJECTS — Orange Line right terminus -->
    <g class="mrt-station" data-station="projects" data-href="/projects">
      <rect class="station-hit" x="1022" y="322" width="56" height="56" fill="transparent" stroke="none"/>
      <rect class="station-square" x="1036" y="336" width="28" height="28"
        fill="#09090b" stroke="#E8753D" stroke-width="2.5" opacity="0.55"/>
      <text class="station-label" x="1050" y="326" text-anchor="middle"
        fill="#E8E4DE" font-family="'IBM Plex Mono',monospace" font-size="14" font-weight="600"
        letter-spacing="0.12em" opacity="0">PROJECTS</text>
    </g>

    <!-- SOCIALS — Blue Line top terminus -->
    <g class="mrt-station" data-station="socials" data-href="https://instagram.com/wildflower" data-external="true">
      <rect class="station-hit" x="572" y="92" width="56" height="56" fill="transparent" stroke="none"/>
      <rect class="station-square" x="586" y="106" width="28" height="28"
        fill="#09090b" stroke="#4A90D9" stroke-width="2.5" opacity="0.55"/>
      <text class="station-label" x="600" y="96" text-anchor="middle"
        fill="#E8E4DE" font-family="'IBM Plex Mono',monospace" font-size="14" font-weight="600"
        letter-spacing="0.12em" opacity="0">SOCIALS</text>
    </g>

    <!-- LIVE — Blue Line bottom terminus -->
    <g class="mrt-station" data-station="live" data-href="/live">
      <rect class="station-hit" x="572" y="572" width="56" height="56" fill="transparent" stroke="none"/>
      <rect class="station-square" x="586" y="586" width="28" height="28"
        fill="#09090b" stroke="#4A90D9" stroke-width="2.5" opacity="0.55"/>
      <text class="station-label" x="600" y="576" text-anchor="middle"
        fill="#E8E4DE" font-family="'IBM Plex Mono',monospace" font-size="14" font-weight="600"
        letter-spacing="0.12em" opacity="0">LIVE</text>
    </g>

    <!-- ═══ PASSENGER LAYER ═══ -->
    <g id="passenger-layer"></g>

    <!-- ═══ TRAINS (larger, more visible) ═══ -->
    <rect id="train-orange" x="-20" y="-6" width="40" height="12" rx="3"
      fill="#E8753D" opacity="0"/>
    <rect id="train-blue" x="-18" y="-6" width="36" height="12" rx="3"
      fill="#4A90D9" opacity="0"/>
  </svg>
</div>

<script>
  import gsap from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';
  gsap.registerPlugin(MotionPathPlugin);

  document.addEventListener('astro:page-load', () => {
    const svg = document.getElementById('mrt-svg');
    const passengerLayer = document.getElementById('passenger-layer');
    if (!svg || !passengerLayer) return;
    const SVG_NS = 'http://www.w3.org/2000/svg';

    // ═══ STATION DATA ═══
    interface StationData {
      id: string;
      x: number;
      y: number;
      queue: { el: SVGCircleElement; dest: string }[];
    }

    const stationMap: Record<string, StationData> = {
      store:    { id: 'store',    x: 150, y: 350, queue: [] },
      artists:  { id: 'artists',  x: 600, y: 350, queue: [] },
      projects: { id: 'projects', x: 1050, y: 350, queue: [] },
      socials:  { id: 'socials',  x: 600, y: 120, queue: [] },
      live:     { id: 'live',     x: 600, y: 600, queue: [] },
    };

    const stationIds = Object.keys(stationMap);
    const MAX_QUEUE = 5;
    const TRAIN_CAPACITY = 4;

    // ═══ PASSENGER SPAWN ═══
    function spawnPassenger() {
      const id = stationIds[Math.floor(Math.random() * stationIds.length)];
      const station = stationMap[id];
      if (station.queue.length >= MAX_QUEUE) return;

      let dest = id;
      while (dest === id) dest = stationIds[Math.floor(Math.random() * stationIds.length)];

      const circle = document.createElementNS(SVG_NS, 'circle');
      circle.setAttribute('r', '5');
      circle.setAttribute('fill', '#E8E4DE');
      circle.setAttribute('opacity', '0.6');

      const idx = station.queue.length;
      const cx = station.x + 28 + idx * 14;
      const cy = station.y;
      circle.setAttribute('cx', String(cx));
      circle.setAttribute('cy', String(cy));

      passengerLayer.appendChild(circle);
      station.queue.push({ el: circle, dest });

      gsap.to(circle, {
        attr: { cy: cy + 3 },
        duration: 1.2 + Math.random() * 0.8,
        ease: 'sine.inOut',
        yoyo: true,
        repeat: -1,
      });
    }

    for (let i = 0; i < 10; i++) setTimeout(spawnPassenger, i * 200);
    const spawnInterval = setInterval(spawnPassenger, 2500);

    // ═══ BOARDING ═══
    function boardPassengers(train: TrainState, stationId: string) {
      const station = stationMap[stationId];
      if (!station) return;
      const available = TRAIN_CAPACITY - train.passengers.length;
      const toBoard = Math.min(available, station.queue.length);

      for (let i = 0; i < toBoard; i++) {
        const p = station.queue.shift()!;
        train.passengers.push({ dest: p.dest, segments: 0 });
        gsap.killTweensOf(p.el);
        gsap.to(p.el, {
          attr: { cx: station.x, cy: station.y },
          opacity: 0,
          duration: 0.3,
          delay: i * 0.1,
          ease: 'power2.in',
          onComplete: () => p.el.remove(),
        });
      }

      station.queue.forEach((p, idx) => {
        gsap.to(p.el, {
          attr: { cx: station.x + 28 + idx * 14 },
          duration: 0.3,
          ease: 'power2.out',
        });
      });
    }

    // ═══ DISEMBARKING ═══
    function disembarkPassengers(train: TrainState, stationId: string) {
      const station = stationMap[stationId];
      if (!station) return;

      const staying: typeof train.passengers = [];
      const leaving: typeof train.passengers = [];

      for (const p of train.passengers) {
        if (p.dest === stationId || p.segments >= 3) {
          leaving.push(p);
        } else {
          p.segments++;
          staying.push(p);
        }
      }

      train.passengers = staying;

      for (let i = 0; i < leaving.length; i++) {
        const circle = document.createElementNS(SVG_NS, 'circle');
        circle.setAttribute('r', '5');
        circle.setAttribute('fill', '#E8E4DE');
        circle.setAttribute('cx', String(station.x));
        circle.setAttribute('cy', String(station.y));
        circle.setAttribute('opacity', '0');
        passengerLayer.appendChild(circle);

        const offsetX = 20 + Math.random() * 40;
        const offsetY = (Math.random() - 0.5) * 30;

        gsap.to(circle, {
          attr: { cx: station.x + offsetX, cy: station.y + offsetY },
          opacity: 0.5,
          duration: 0.35,
          delay: i * 0.12,
          ease: 'power2.out',
        });
        gsap.to(circle, {
          opacity: 0,
          duration: 0.6,
          delay: 1.5 + i * 0.15,
          onComplete: () => circle.remove(),
        });
      }
    }

    // ═══ TRAIN STATE ═══
    interface TrainPassenger { dest: string; segments: number; }
    interface TrainState {
      el: HTMLElement;
      trackId: string;
      passengers: TrainPassenger[];
      stops: number[];
      stationIds: string[];
      currentStop: number;
      direction: 1 | -1;
      baseOpacity: number;
    }

    function advanceTrain(train: TrainState) {
      const next = train.currentStop + train.direction;
      if (next < 0 || next >= train.stops.length) {
        train.direction *= -1 as 1 | -1;
        setTimeout(() => advanceTrain(train), 600);
        return;
      }

      const trackSel = `#${train.trackId}`;
      const dist = Math.abs(train.stops[next] - train.stops[train.currentStop]);
      const duration = Math.max(dist * 8, 0.6);

      gsap.to(train.el, {
        duration,
        motionPath: {
          path: trackSel, align: trackSel,
          alignOrigin: [0.5, 0.5], autoRotate: true,
          start: train.stops[train.currentStop], end: train.stops[next],
        },
        ease: 'power2.inOut',
        onComplete: () => {
          train.currentStop = next;
          dwell(train, train.stationIds[next]);
        },
      });
    }

    function dwell(train: TrainState, stationId: string) {
      disembarkPassengers(train, stationId);
      setTimeout(() => boardPassengers(train, stationId), 400);
      setTimeout(() => advanceTrain(train), 1200);
    }

    function initTrain(train: TrainState, startDelay: number) {
      const trackSel = `#${train.trackId}`;
      if (!document.querySelector(trackSel)) return;

      gsap.set(train.el, {
        motionPath: { path: trackSel, align: trackSel,
          alignOrigin: [0.5, 0.5], autoRotate: true, start: 0, end: 0 },
      });
      gsap.to(train.el, { opacity: train.baseOpacity, duration: 0.6, delay: startDelay / 1000 });
      setTimeout(() => advanceTrain(train), startDelay);
    }

    // ═══ CONFIGURE TRAINS ═══

    // Orange Line: STORE → ARTISTS → PROJECTS (straight horizontal)
    const trainOrange: TrainState = {
      el: document.getElementById('train-orange')!,
      trackId: 'track-orange',
      passengers: [],
      stops: [0, 0.28, 0.50, 0.72, 1.0],
      stationIds: ['store', '', 'artists', '', 'projects'],
      currentStop: 0, direction: 1, baseOpacity: 0.9,
    };

    // Blue Line: SOCIALS → ARTISTS → LIVE (straight vertical)
    const trainBlue: TrainState = {
      el: document.getElementById('train-blue')!,
      trackId: 'track-blue',
      passengers: [],
      stops: [0, 0.21, 0.48, 0.75, 1.0],
      stationIds: ['socials', '', 'artists', '', 'live'],
      currentStop: 0, direction: 1, baseOpacity: 0.9,
    };

    initTrain(trainOrange, 500);
    initTrain(trainBlue, 2000);

    // ═══ STATION HOVER — typewriter label reveal ═══
    const stationEls = document.querySelectorAll('.mrt-station');
    stationEls.forEach((el) => {
      const square = el.querySelector('.station-square') as SVGRectElement;
      const label = el.querySelector('.station-label') as SVGTextElement;
      if (!square || !label) return;

      const fullText = label.textContent || '';
      let hoverTween: gsap.core.Tween | null = null;
      let typeInterval: ReturnType<typeof setInterval> | null = null;

      el.addEventListener('mouseenter', () => {
        if ((window as any).playBlip) (window as any).playBlip();
        hoverTween = gsap.to(square, { opacity: 1, duration: 0.2, ease: 'power2.out' });

        let charIdx = 0;
        label.textContent = '';
        gsap.set(label, { opacity: 1 });
        typeInterval = setInterval(() => {
          charIdx++;
          label.textContent = fullText.slice(0, charIdx);
          if (charIdx >= fullText.length && typeInterval) { clearInterval(typeInterval); typeInterval = null; }
        }, 40);
      });

      el.addEventListener('mouseleave', () => {
        if (typeInterval) { clearInterval(typeInterval); typeInterval = null; }
        if (hoverTween) hoverTween.kill();
        gsap.to(square, { opacity: 0.55, duration: 0.3, ease: 'power2.in' });
        gsap.to(label, { opacity: 0, duration: 0.2, ease: 'power2.in',
          onComplete: () => { label.textContent = fullText; } });
      });

      el.addEventListener('click', () => {
        const href = el.getAttribute('data-href');
        const external = el.getAttribute('data-external');
        if (!href) return;
        if ((window as any).playClick) (window as any).playClick();
        if (external === 'true') window.open(href, '_blank', 'noopener');
        else window.location.href = href;
      });

      (el as HTMLElement).style.cursor = 'pointer';
    });

    // ═══ CLEANUP ═══
    document.addEventListener('astro:before-swap', () => { clearInterval(spawnInterval); }, { once: true });
  });
</script>
