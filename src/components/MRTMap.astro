---
// MRT Map — Mini Metro × WILDFLOWER
// 3 colored lines, 5 functional stations, autonomous passenger ecosystem
// Trains: decelerate → dwell 1.2s → accelerate (GSAP MotionPath)
// Passengers: spawn → queue → board → ride → disembark
---

<div class="w-full h-screen relative overflow-hidden" id="mrt-container">
  <svg
    id="mrt-svg"
    viewBox="0 50 1600 900"
    class="w-full h-full select-none"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid slice"
  >
    <!-- ═══ TRACKS (8px, bold Mini Metro style, clean 45° bends) ═══ -->

    <!-- Copper Line: STORE → ARTISTS → PROJECTS (main horizontal trunk with 45° kinks) -->
    <path id="track-copper"
      d="M 380,440 L 540,440 L 620,520 L 720,520 L 800,520 L 900,520 L 980,440 L 1220,440"
      fill="none" stroke="#C27853" stroke-width="8" opacity="0.22"
      stroke-linecap="round" stroke-linejoin="round"/>

    <!-- Bone Line: STORE → up → SOCIALS → down → PROJECTS (upper arc) -->
    <path id="track-bone"
      d="M 380,440 L 440,380 L 520,280 L 660,280 L 800,280 L 940,280 L 1060,380 L 1160,440 L 1220,440"
      fill="none" stroke="#E8E4DE" stroke-width="8" opacity="0.22"
      stroke-linecap="round" stroke-linejoin="round"/>

    <!-- Slate Line: ARTISTS → LIVE (vertical drop south) -->
    <path id="track-slate"
      d="M 800,520 L 800,600 L 800,720 L 760,790"
      fill="none" stroke="#6B7B8D" stroke-width="8" opacity="0.22"
      stroke-linecap="round" stroke-linejoin="round"/>

    <!-- ═══ STATIONS (18×18 hollow squares, generous hit areas) ═══ -->

    <!-- STORE — Copper ∩ Bone transfer (left) -->
    <g class="mrt-station" data-station="store" data-href="https://shop.wild-flower.co" data-external="true">
      <rect class="station-hit" x="362" y="422" width="36" height="36" fill="transparent" stroke="none"/>
      <rect class="station-square" x="371" y="431" width="18" height="18"
        fill="#09090b" stroke="#C27853" stroke-width="1.5" opacity="0.3"/>
      <text class="station-label" x="371" y="421" text-anchor="start"
        fill="#D4D0C8" font-family="'IBM Plex Mono',monospace" font-size="12" font-weight="500"
        letter-spacing="0.1em" opacity="0">STORE</text>
    </g>

    <!-- ARTISTS — Copper ∩ Slate transfer (center) -->
    <g class="mrt-station" data-station="artists" data-href="/artists">
      <rect class="station-hit" x="782" y="502" width="36" height="36" fill="transparent" stroke="none"/>
      <rect class="station-square" x="791" y="511" width="18" height="18"
        fill="#09090b" stroke="#C27853" stroke-width="1.5" opacity="0.3"/>
      <text class="station-label" x="791" y="501" text-anchor="start"
        fill="#D4D0C8" font-family="'IBM Plex Mono',monospace" font-size="12" font-weight="500"
        letter-spacing="0.1em" opacity="0">ARTISTS</text>
    </g>

    <!-- PROJECTS — Copper ∩ Bone transfer (right) -->
    <g class="mrt-station" data-station="projects" data-href="/projects">
      <rect class="station-hit" x="1202" y="422" width="36" height="36" fill="transparent" stroke="none"/>
      <rect class="station-square" x="1211" y="431" width="18" height="18"
        fill="#09090b" stroke="#E8E4DE" stroke-width="1.5" opacity="0.3"/>
      <text class="station-label" x="1211" y="421" text-anchor="start"
        fill="#D4D0C8" font-family="'IBM Plex Mono',monospace" font-size="12" font-weight="500"
        letter-spacing="0.1em" opacity="0">PROJECTS</text>
    </g>

    <!-- SOCIALS — Bone line (top center) -->
    <g class="mrt-station" data-station="socials" data-href="https://instagram.com/wildflower" data-external="true">
      <rect class="station-hit" x="782" y="262" width="36" height="36" fill="transparent" stroke="none"/>
      <rect class="station-square" x="791" y="271" width="18" height="18"
        fill="#09090b" stroke="#E8E4DE" stroke-width="1.5" opacity="0.3"/>
      <text class="station-label" x="791" y="261" text-anchor="start"
        fill="#D4D0C8" font-family="'IBM Plex Mono',monospace" font-size="12" font-weight="500"
        letter-spacing="0.1em" opacity="0">SOCIALS</text>
    </g>

    <!-- LIVE — Slate terminus (bottom) -->
    <g class="mrt-station" data-station="live" data-href="/live">
      <rect class="station-hit" x="742" y="772" width="36" height="36" fill="transparent" stroke="none"/>
      <rect class="station-square" x="751" y="781" width="18" height="18"
        fill="#09090b" stroke="#6B7B8D" stroke-width="1.5" opacity="0.3"/>
      <text class="station-label" x="751" y="771" text-anchor="start"
        fill="#D4D0C8" font-family="'IBM Plex Mono',monospace" font-size="12" font-weight="500"
        letter-spacing="0.1em" opacity="0">LIVE</text>
    </g>

    <!-- ═══ PASSENGER LAYER ═══ -->
    <g id="passenger-layer"></g>

    <!-- ═══ TRAINS (small rounded rects, no glow) ═══ -->
    <rect id="train-copper" x="-16" y="-5" width="32" height="10" rx="2"
      fill="#C27853" opacity="0"/>
    <rect id="train-bone" x="-16" y="-5" width="32" height="10" rx="2"
      fill="#E8E4DE" opacity="0"/>
    <rect id="train-slate" x="-14" y="-4" width="28" height="8" rx="2"
      fill="#6B7B8D" opacity="0"/>
  </svg>
</div>

<script>
  import gsap from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';
  gsap.registerPlugin(MotionPathPlugin);

  document.addEventListener('astro:page-load', () => {
    const svg = document.getElementById('mrt-svg');
    const passengerLayer = document.getElementById('passenger-layer');
    if (!svg || !passengerLayer) return;
    const SVG_NS = 'http://www.w3.org/2000/svg';

    // ═══ STATION DATA ═══
    interface StationData {
      id: string;
      x: number;
      y: number;
      queue: { el: SVGCircleElement; dest: string }[];
    }

    const stationMap: Record<string, StationData> = {
      store:    { id: 'store',    x: 380, y: 440, queue: [] },
      artists:  { id: 'artists',  x: 800, y: 520, queue: [] },
      projects: { id: 'projects', x: 1220, y: 440, queue: [] },
      socials:  { id: 'socials',  x: 800, y: 280, queue: [] },
      live:     { id: 'live',     x: 760, y: 790, queue: [] },
    };

    const stationIds = Object.keys(stationMap);
    const MAX_QUEUE = 5;
    const TRAIN_CAPACITY = 4;

    // ═══ PASSENGER SPAWN ═══
    function spawnPassenger() {
      const id = stationIds[Math.floor(Math.random() * stationIds.length)];
      const station = stationMap[id];
      if (station.queue.length >= MAX_QUEUE) return;

      let dest = id;
      while (dest === id) dest = stationIds[Math.floor(Math.random() * stationIds.length)];

      const circle = document.createElementNS(SVG_NS, 'circle');
      circle.setAttribute('r', '4');
      circle.setAttribute('fill', '#D4D0C8');
      circle.setAttribute('opacity', '0.45');

      const idx = station.queue.length;
      const cx = station.x + 22 + idx * 11;
      const cy = station.y;
      circle.setAttribute('cx', String(cx));
      circle.setAttribute('cy', String(cy));

      passengerLayer.appendChild(circle);
      station.queue.push({ el: circle, dest });

      gsap.to(circle, {
        attr: { cy: cy + 3 },
        duration: 1.2 + Math.random() * 0.8,
        ease: 'sine.inOut',
        yoyo: true,
        repeat: -1,
      });
    }

    for (let i = 0; i < 10; i++) setTimeout(spawnPassenger, i * 200);
    const spawnInterval = setInterval(spawnPassenger, 2500);

    // ═══ BOARDING ═══
    function boardPassengers(train: TrainState, stationId: string) {
      const station = stationMap[stationId];
      if (!station) return;
      const available = TRAIN_CAPACITY - train.passengers.length;
      const toBoard = Math.min(available, station.queue.length);

      for (let i = 0; i < toBoard; i++) {
        const p = station.queue.shift()!;
        train.passengers.push({ dest: p.dest, segments: 0 });
        gsap.killTweensOf(p.el);
        gsap.to(p.el, {
          attr: { cx: station.x, cy: station.y },
          opacity: 0,
          duration: 0.3,
          delay: i * 0.1,
          ease: 'power2.in',
          onComplete: () => p.el.remove(),
        });
      }

      station.queue.forEach((p, idx) => {
        gsap.to(p.el, {
          attr: { cx: station.x + 22 + idx * 11 },
          duration: 0.3,
          ease: 'power2.out',
        });
      });
    }

    // ═══ DISEMBARKING ═══
    function disembarkPassengers(train: TrainState, stationId: string) {
      const station = stationMap[stationId];
      if (!station) return;

      const staying: typeof train.passengers = [];
      const leaving: typeof train.passengers = [];

      for (const p of train.passengers) {
        if (p.dest === stationId || p.segments >= 3) {
          leaving.push(p);
        } else {
          p.segments++;
          staying.push(p);
        }
      }

      train.passengers = staying;

      for (let i = 0; i < leaving.length; i++) {
        const circle = document.createElementNS(SVG_NS, 'circle');
        circle.setAttribute('r', '4');
        circle.setAttribute('fill', '#D4D0C8');
        circle.setAttribute('cx', String(station.x));
        circle.setAttribute('cy', String(station.y));
        circle.setAttribute('opacity', '0');
        passengerLayer.appendChild(circle);

        const offsetX = 18 + Math.random() * 35;
        const offsetY = (Math.random() - 0.5) * 28;

        gsap.to(circle, {
          attr: { cx: station.x + offsetX, cy: station.y + offsetY },
          opacity: 0.4,
          duration: 0.35,
          delay: i * 0.12,
          ease: 'power2.out',
        });
        gsap.to(circle, {
          opacity: 0,
          duration: 0.6,
          delay: 1.5 + i * 0.15,
          onComplete: () => circle.remove(),
        });
      }
    }

    // ═══ TRAIN STATE ═══
    interface TrainPassenger {
      dest: string;
      segments: number;
    }

    interface TrainState {
      el: HTMLElement;
      trackId: string;
      passengers: TrainPassenger[];
      stops: number[];
      stationIds: string[];
      currentStop: number;
      direction: 1 | -1;
      baseOpacity: number;
    }

    // ═══ TRAIN MOVEMENT ═══
    function advanceTrain(train: TrainState) {
      const next = train.currentStop + train.direction;

      if (next < 0 || next >= train.stops.length) {
        train.direction *= -1 as 1 | -1;
        setTimeout(() => advanceTrain(train), 600);
        return;
      }

      const trackSel = `#${train.trackId}`;
      const dist = Math.abs(train.stops[next] - train.stops[train.currentStop]);
      const duration = Math.max(dist * 8, 0.6);

      gsap.to(train.el, {
        duration,
        motionPath: {
          path: trackSel,
          align: trackSel,
          alignOrigin: [0.5, 0.5],
          autoRotate: true,
          start: train.stops[train.currentStop],
          end: train.stops[next],
        },
        ease: 'power2.inOut',
        onComplete: () => {
          train.currentStop = next;
          const stationId = train.stationIds[next];
          dwell(train, stationId);
        },
      });
    }

    function dwell(train: TrainState, stationId: string) {
      disembarkPassengers(train, stationId);
      setTimeout(() => boardPassengers(train, stationId), 400);
      setTimeout(() => advanceTrain(train), 1200);
    }

    function initTrain(train: TrainState, startDelay: number) {
      const trackSel = `#${train.trackId}`;
      if (!document.querySelector(trackSel)) return;

      gsap.set(train.el, {
        motionPath: {
          path: trackSel,
          align: trackSel,
          alignOrigin: [0.5, 0.5],
          autoRotate: true,
          start: 0,
          end: 0,
        },
      });

      gsap.to(train.el, {
        opacity: train.baseOpacity,
        duration: 0.6,
        delay: startDelay / 1000,
      });

      setTimeout(() => advanceTrain(train), startDelay);
    }

    // ═══ CONFIGURE TRAINS ═══

    // Copper Line: STORE → bend → ARTISTS → bend → PROJECTS
    // Path: 260,440 → 460,440 → 540,520 → 720,520 → 800,520 → 980,520 → 1060,440 → 1340,440
    const trainCopper: TrainState = {
      el: document.getElementById('train-copper')!,
      trackId: 'track-copper',
      passengers: [],
      stops: [0, 0.16, 0.23, 0.38, 0.44, 0.58, 0.65, 1.0],
      stationIds: ['store', '', '', '', 'artists', '', '', 'projects'],
      currentStop: 0,
      direction: 1,
      baseOpacity: 0.8,
    };

    // Bone Line: STORE → up → SOCIALS → down → PROJECTS
    // Path: 260,440 → 340,360 → 460,240 → 640,240 → 800,240 → 960,240 → 1100,360 → 1260,440 → 1340,440
    const trainBone: TrainState = {
      el: document.getElementById('train-bone')!,
      trackId: 'track-bone',
      passengers: [],
      stops: [0, 0.08, 0.20, 0.35, 0.50, 0.65, 0.78, 0.92, 1.0],
      stationIds: ['store', '', '', '', 'socials', '', '', '', 'projects'],
      currentStop: 0,
      direction: 1,
      baseOpacity: 0.8,
    };

    // Slate Line: ARTISTS → down → LIVE
    // Path: 800,520 → 800,600 → 800,740 → 760,810
    const trainSlate: TrainState = {
      el: document.getElementById('train-slate')!,
      trackId: 'track-slate',
      passengers: [],
      stops: [0, 0.28, 0.76, 1.0],
      stationIds: ['artists', '', '', 'live'],
      currentStop: 0,
      direction: 1,
      baseOpacity: 0.8,
    };

    initTrain(trainCopper, 500);
    initTrain(trainBone, 1800);
    initTrain(trainSlate, 3200);

    // ═══ STATION HOVER — typewriter label reveal ═══
    const stationEls = document.querySelectorAll('.mrt-station');
    stationEls.forEach((el) => {
      const square = el.querySelector('.station-square') as SVGRectElement;
      const label = el.querySelector('.station-label') as SVGTextElement;
      if (!square || !label) return;

      const fullText = label.textContent || '';
      let hoverTween: gsap.core.Tween | null = null;
      let typeInterval: ReturnType<typeof setInterval> | null = null;

      el.addEventListener('mouseenter', () => {
        if ((window as any).playBlip) (window as any).playBlip();

        hoverTween = gsap.to(square, {
          opacity: 1,
          duration: 0.25,
          ease: 'power2.out',
        });

        let charIdx = 0;
        label.textContent = '';
        gsap.set(label, { opacity: 1 });
        typeInterval = setInterval(() => {
          charIdx++;
          label.textContent = fullText.slice(0, charIdx);
          if (charIdx >= fullText.length && typeInterval) {
            clearInterval(typeInterval);
            typeInterval = null;
          }
        }, 40);
      });

      el.addEventListener('mouseleave', () => {
        if (typeInterval) { clearInterval(typeInterval); typeInterval = null; }
        if (hoverTween) hoverTween.kill();

        gsap.to(square, { opacity: 0.3, duration: 0.3, ease: 'power2.in' });
        gsap.to(label, {
          opacity: 0,
          duration: 0.2,
          ease: 'power2.in',
          onComplete: () => { label.textContent = fullText; },
        });
      });

      el.addEventListener('click', () => {
        const href = el.getAttribute('data-href');
        const external = el.getAttribute('data-external');
        if (!href) return;

        if ((window as any).playClick) (window as any).playClick();

        if (external === 'true') {
          window.open(href, '_blank', 'noopener');
        } else {
          window.location.href = href;
        }
      });

      (el as HTMLElement).style.cursor = 'pointer';
    });

    // ═══ CLEANUP ═══
    document.addEventListener('astro:before-swap', () => {
      clearInterval(spawnInterval);
    }, { once: true });
  });
</script>
