---
// MRT Map — Taipei Metro × Mini Metro
// 3 colored lines (White, Green, Gray), wide river, oversized stations
// Autonomous passenger system: spawn → wait → board → ride → disembark
---

<canvas id="rain-canvas" class="fixed inset-0 pointer-events-none z-[1]"></canvas>

<div class="w-full h-screen relative z-[2] overflow-hidden" id="mrt-container">
  <div id="mrt-pan-wrapper" class="w-full h-full flex items-center justify-center md:pointer-events-none">
    <svg
      id="mrt-svg"
      viewBox="0 0 1800 950"
      class="w-[300%] md:w-full md:h-full select-none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid meet"
    >
      <!-- ═══ RIVER (wide authority band) ═══ -->
      <path d="M 1050,-20 Q 1060,170 1050,340 Q 1015,440 980,540 Q 970,745 980,970"
        fill="none" stroke="#1a3a5c" stroke-width="55" opacity="0.10"
        stroke-linecap="round" stroke-linejoin="round"/>

      <!-- ═══ TRACKS (8px wide, high contrast) ═══ -->

      <!-- Gray Line (upper diagonal) -->
      <path id="track-gray"
        d="M 200,280 L 500,280 L 700,160 L 1050,160 L 1250,280 L 1500,280"
        fill="none" stroke="#808080" stroke-width="8" opacity="0.45"
        stroke-linecap="round" stroke-linejoin="round"/>

      <!-- Green Line (north-south) -->
      <path id="track-green"
        d="M 500,80 L 500,280 L 500,420 L 600,520 L 600,750 L 500,850"
        fill="none" stroke="#00ff88" stroke-width="8" opacity="0.35"
        stroke-linecap="round" stroke-linejoin="round"/>

      <!-- White Line (horizontal main, most prominent) -->
      <path id="track-white"
        d="M 100,520 L 400,520 L 500,420 L 800,420 L 900,520 L 1200,520 L 1300,420 L 1600,420 L 1700,520"
        fill="none" stroke="#f0f0f0" stroke-width="8" opacity="0.50"
        stroke-linecap="round" stroke-linejoin="round"/>

      <!-- ═══ GHOST STATIONS (unlabeled, low opacity, oversized squares) ═══ -->

      <!-- White Line ghosts -->
      <rect x="88" y="508" width="24" height="24" fill="#0a0a0a" stroke="#f0f0f0" stroke-width="2" opacity="0.20"/>
      <rect x="388" y="508" width="24" height="24" fill="#0a0a0a" stroke="#f0f0f0" stroke-width="2" opacity="0.20"/>
      <rect x="788" y="408" width="24" height="24" fill="#0a0a0a" stroke="#f0f0f0" stroke-width="2" opacity="0.20"/>
      <rect x="888" y="508" width="24" height="24" fill="#0a0a0a" stroke="#f0f0f0" stroke-width="2" opacity="0.20"/>
      <rect x="1188" y="508" width="24" height="24" fill="#0a0a0a" stroke="#f0f0f0" stroke-width="2" opacity="0.20"/>
      <rect x="1588" y="408" width="24" height="24" fill="#0a0a0a" stroke="#f0f0f0" stroke-width="2" opacity="0.20"/>
      <rect x="1688" y="508" width="24" height="24" fill="#0a0a0a" stroke="#f0f0f0" stroke-width="2" opacity="0.20"/>

      <!-- Green Line ghosts -->
      <rect x="488" y="268" width="24" height="24" fill="#0a0a0a" stroke="#00ff88" stroke-width="2" opacity="0.20"/>
      <rect x="588" y="508" width="24" height="24" fill="#0a0a0a" stroke="#00ff88" stroke-width="2" opacity="0.20"/>
      <rect x="588" y="738" width="24" height="24" fill="#0a0a0a" stroke="#00ff88" stroke-width="2" opacity="0.20"/>

      <!-- Gray Line ghosts -->
      <rect x="188" y="268" width="24" height="24" fill="#0a0a0a" stroke="#808080" stroke-width="2" opacity="0.20"/>
      <rect x="688" y="148" width="24" height="24" fill="#0a0a0a" stroke="#808080" stroke-width="2" opacity="0.20"/>
      <rect x="1038" y="148" width="24" height="24" fill="#0a0a0a" stroke="#808080" stroke-width="2" opacity="0.20"/>
      <rect x="1238" y="268" width="24" height="24" fill="#0a0a0a" stroke="#808080" stroke-width="2" opacity="0.20"/>

      <!-- ═══ LABELED STATIONS (bright, oversized, bold text) ═══ -->

      <!-- 商店 (Store) — Green Line north terminal -->
      <g class="mrt-station" data-clickable>
        <a href="https://shop.wild-flower.co" target="_blank" rel="noopener">
          <rect x="488" y="68" width="24" height="24" fill="#0a0a0a" stroke="#00ff88" stroke-width="2.5" opacity="0.85"/>
          <text x="524" y="88" text-anchor="start" fill="#f0f0f0" font-family="'Noto Sans TC',sans-serif" font-size="32" font-weight="400" opacity="0.70">商店</text>
        </a>
      </g>

      <!-- 成員 (Artists) — White × Green transfer -->
      <g class="mrt-station" data-clickable>
        <a href="/artists">
          <rect x="488" y="408" width="24" height="24" fill="#0a0a0a" stroke="#f0f0f0" stroke-width="2.5" opacity="0.85"/>
          <text x="524" y="428" text-anchor="start" fill="#f0f0f0" font-family="'Noto Sans TC',sans-serif" font-size="32" font-weight="400" opacity="0.70">成員</text>
        </a>
      </g>

      <!-- 專案 (Projects) — White Line east of river -->
      <g class="mrt-station" data-clickable>
        <a href="/projects">
          <rect x="1288" y="408" width="24" height="24" fill="#0a0a0a" stroke="#f0f0f0" stroke-width="2.5" opacity="0.85"/>
          <text x="1324" y="428" text-anchor="start" fill="#f0f0f0" font-family="'Noto Sans TC',sans-serif" font-size="32" font-weight="400" opacity="0.70">專案</text>
        </a>
      </g>

      <!-- 社群 (Social) — Gray Line east -->
      <g class="mrt-station" data-clickable>
        <a href="https://instagram.com/wildflower" target="_blank" rel="noopener">
          <rect x="1488" y="268" width="24" height="24" fill="#0a0a0a" stroke="#808080" stroke-width="2.5" opacity="0.85"/>
          <text x="1524" y="288" text-anchor="start" fill="#f0f0f0" font-family="'Noto Sans TC',sans-serif" font-size="32" font-weight="400" opacity="0.70">社群</text>
        </a>
      </g>

      <!-- 演出 (Live) — Green Line south terminal -->
      <g class="mrt-station" data-clickable>
        <a href="/live">
          <rect x="488" y="838" width="24" height="24" fill="#0a0a0a" stroke="#00ff88" stroke-width="2.5" opacity="0.85"/>
          <text x="524" y="858" text-anchor="start" fill="#f0f0f0" font-family="'Noto Sans TC',sans-serif" font-size="32" font-weight="400" opacity="0.70">演出</text>
        </a>
      </g>

      <!-- ═══ PASSENGER LAYER (dynamic SVG circles created by JS) ═══ -->
      <g id="passenger-layer"></g>

      <!-- ═══ TRAINS (rectangles, one per line) ═══ -->
      <rect id="train-white" x="-14" y="-3" width="28" height="6" rx="1" fill="#f0f0f0" opacity="0.85"/>
      <rect id="train-green" x="-12" y="-3" width="24" height="6" rx="1" fill="#00ff88" opacity="0.70"/>
      <rect id="train-gray" x="-11" y="-2.5" width="22" height="5" rx="1" fill="#808080" opacity="0.60"/>
    </svg>
  </div>
</div>

<script>
  import gsap from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';
  gsap.registerPlugin(MotionPathPlugin);

  document.addEventListener('astro:page-load', () => {
    // ═══ RAIN ═══
    const canvas = document.getElementById('rain-canvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d')!;
      let aId: number;
      const resize = () => { canvas.width = innerWidth; canvas.height = innerHeight; };
      resize(); addEventListener('resize', resize);
      const drops: { x: number; y: number; speed: number; len: number; op: number }[] = [];
      for (let i = 0; i < Math.floor(innerWidth / 12); i++)
        drops.push({
          x: Math.random() * canvas.width, y: Math.random() * canvas.height,
          speed: 1 + Math.random() * 2, len: 6 + Math.random() * 12,
          op: 0.015 + Math.random() * 0.025
        });
      const draw = () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        for (const d of drops) {
          ctx.beginPath(); ctx.moveTo(d.x, d.y); ctx.lineTo(d.x + 0.3, d.y + d.len);
          ctx.strokeStyle = `rgba(240,240,240,${d.op})`; ctx.lineWidth = 0.5; ctx.stroke();
          d.y += d.speed;
          if (d.y > canvas.height) { d.y = -d.len; d.x = Math.random() * canvas.width; }
        }
        aId = requestAnimationFrame(draw);
      };
      draw();
      document.addEventListener('astro:before-swap', () => cancelAnimationFrame(aId), { once: true });
    }

    // ═══ SVG REFERENCES ═══
    const svg = document.getElementById('mrt-svg');
    const passengerLayer = document.getElementById('passenger-layer');
    if (!svg || !passengerLayer) return;
    const SVG_NS = 'http://www.w3.org/2000/svg';

    // ═══ STATION DATA ═══
    interface StationData {
      name: string;
      x: number;
      y: number;
      labeled: boolean;
      waiting: SVGCircleElement[];
    }

    const stations: StationData[] = [
      // White Line
      { name: '', x: 100, y: 520, labeled: false, waiting: [] },
      { name: '', x: 400, y: 520, labeled: false, waiting: [] },
      { name: '成員', x: 500, y: 420, labeled: true, waiting: [] },
      { name: '', x: 800, y: 420, labeled: false, waiting: [] },
      { name: '', x: 900, y: 520, labeled: false, waiting: [] },
      { name: '', x: 1200, y: 520, labeled: false, waiting: [] },
      { name: '專案', x: 1300, y: 420, labeled: true, waiting: [] },
      { name: '', x: 1600, y: 420, labeled: false, waiting: [] },
      { name: '', x: 1700, y: 520, labeled: false, waiting: [] },
      // Green Line (unique positions)
      { name: '商店', x: 500, y: 80, labeled: true, waiting: [] },
      { name: '', x: 500, y: 280, labeled: false, waiting: [] },
      { name: '', x: 600, y: 520, labeled: false, waiting: [] },
      { name: '', x: 600, y: 750, labeled: false, waiting: [] },
      { name: '演出', x: 500, y: 850, labeled: true, waiting: [] },
      // Gray Line (unique positions)
      { name: '', x: 200, y: 280, labeled: false, waiting: [] },
      { name: '', x: 700, y: 160, labeled: false, waiting: [] },
      { name: '', x: 1050, y: 160, labeled: false, waiting: [] },
      { name: '', x: 1250, y: 280, labeled: false, waiting: [] },
      { name: '社群', x: 1500, y: 280, labeled: true, waiting: [] },
    ];

    const labeledStations = stations.filter(s => s.labeled);
    const MAX_WAITING = 4;
    const TRAIN_CAPACITY = 4;

    // Find station by approximate coordinates
    function findStation(x: number, y: number): StationData | undefined {
      return stations.find(s => Math.abs(s.x - x) < 10 && Math.abs(s.y - y) < 10);
    }

    // ═══ PASSENGER SPAWN ═══
    function spawnPassenger() {
      const station = labeledStations[Math.floor(Math.random() * labeledStations.length)];
      if (station.waiting.length >= MAX_WAITING) return;

      const circle = document.createElementNS(SVG_NS, 'circle');
      circle.setAttribute('r', '3.5');
      circle.setAttribute('fill', '#f0f0f0');
      circle.setAttribute('opacity', '0.65');

      // Neat row to the right of station square
      const idx = station.waiting.length;
      const cx = station.x + 20 + idx * 10;
      const cy = station.y;
      circle.setAttribute('cx', String(cx));
      circle.setAttribute('cy', String(cy));

      passengerLayer.appendChild(circle);
      station.waiting.push(circle);

      // Gentle idle bobbing
      gsap.to(circle, {
        attr: { cy: cy + 2.5 },
        duration: 1.5 + Math.random(),
        ease: 'sine.inOut',
        yoyo: true,
        repeat: -1
      });
    }

    // Spawn initial batch
    for (let i = 0; i < 8; i++) setTimeout(spawnPassenger, i * 250);
    // Continuous spawning
    const spawnInterval = setInterval(() => spawnPassenger(), 2500 + Math.random() * 1500);

    // ═══ BOARDING (passengers slide into train) ═══
    function boardPassengers(train: TrainState, station: StationData) {
      const canBoard = Math.min(TRAIN_CAPACITY - train.passengerCount, station.waiting.length);
      for (let i = 0; i < canBoard; i++) {
        const p = station.waiting.shift()!;
        train.passengerCount++;
        gsap.killTweensOf(p);
        gsap.to(p, {
          attr: { cx: station.x, cy: station.y },
          opacity: 0,
          duration: 0.35,
          delay: i * 0.12,
          ease: 'power2.in',
          onComplete: () => p.remove()
        });
      }
    }

    // ═══ DISEMBARKING (passengers exit at station) ═══
    function disembarkPassengers(train: TrainState, station: StationData) {
      if (train.passengerCount === 0) return;
      const count = Math.min(1 + Math.floor(Math.random() * 2), train.passengerCount);
      for (let i = 0; i < count; i++) {
        train.passengerCount--;
        const circle = document.createElementNS(SVG_NS, 'circle');
        circle.setAttribute('r', '3.5');
        circle.setAttribute('fill', '#f0f0f0');
        circle.setAttribute('cx', String(station.x));
        circle.setAttribute('cy', String(station.y));
        circle.setAttribute('opacity', '0');
        passengerLayer.appendChild(circle);

        const offsetX = 15 + Math.random() * 25;
        const offsetY = (Math.random() - 0.5) * 20;
        // Appear and slide out
        gsap.to(circle, {
          attr: { cx: station.x + offsetX, cy: station.y + offsetY },
          opacity: 0.5,
          duration: 0.4,
          delay: 0.2 + i * 0.15,
          ease: 'power2.out'
        });
        // Fade out and remove
        gsap.to(circle, {
          opacity: 0,
          duration: 0.8,
          delay: 2 + i * 0.2,
          onComplete: () => circle.remove()
        });
      }
    }

    // ═══ TRAIN STATE ═══
    interface TrainState {
      el: HTMLElement;
      trackId: string;
      passengerCount: number;
      baseOpacity: number;
    }

    // ═══ TRAIN MOVEMENT (decelerate → pause → board/disembark → accelerate) ═══
    function runTrain(
      train: TrainState,
      stops: number[],
      stationCoords: { x: number; y: number }[],
      startDelay: number
    ) {
      const el = train.el;
      const trackSel = `#${train.trackId}`;
      if (!el || !document.querySelector(trackSel)) return;

      let cur = 0;
      let direction = 1; // 1=forward, -1=backward

      function go() {
        const next = cur + direction;

        // Reverse at endpoints
        if (next < 0 || next >= stops.length) {
          direction *= -1;
          // Brief terminal dwell
          setTimeout(() => go(), 800);
          return;
        }

        const dist = Math.abs(stops[next] - stops[cur]);
        const duration = dist * 10; // scale by path distance

        gsap.to(el, {
          duration: Math.max(duration, 0.8),
          motionPath: {
            path: trackSel,
            align: trackSel,
            alignOrigin: [0.5, 0.5],
            autoRotate: true,
            start: stops[cur],
            end: stops[next]
          },
          ease: 'power2.inOut', // decelerate in, accelerate out
          onComplete: () => {
            cur = next;
            const coord = stationCoords[cur];
            const station = coord ? findStation(coord.x, coord.y) : undefined;

            if (station && station.labeled) {
              // Labeled station: full dwell with boarding/disembarking
              disembarkPassengers(train, station);
              setTimeout(() => {
                boardPassengers(train, station);
                setTimeout(go, 600); // remaining dwell
              }, 600);
            } else {
              // Ghost station: brief pause
              setTimeout(go, 300 + Math.random() * 200);
            }
          }
        });
      }

      // Initialize position
      gsap.set(el, {
        motionPath: {
          path: trackSel, align: trackSel,
          alignOrigin: [0.5, 0.5], autoRotate: true,
          start: 0, end: 0
        }
      });
      setTimeout(go, startDelay);
    }

    // ═══ CONFIGURE TRAINS ═══

    // White Line path fractions (computed from segment lengths)
    // Total length ≈ 1766: 300+141+300+141+300+141+300+141
    const whiteStops = [0, 0.170, 0.250, 0.420, 0.500, 0.670, 0.750, 0.920, 1.0];
    const whiteCoords = [
      { x: 100, y: 520 }, { x: 400, y: 520 }, { x: 500, y: 420 },
      { x: 800, y: 420 }, { x: 900, y: 520 }, { x: 1200, y: 520 },
      { x: 1300, y: 420 }, { x: 1600, y: 420 }, { x: 1700, y: 520 }
    ];

    // Green Line path fractions
    // Total ≈ 853: 200+140+141+230+141
    const greenStops = [0, 0.235, 0.399, 0.564, 0.834, 1.0];
    const greenCoords = [
      { x: 500, y: 80 }, { x: 500, y: 280 }, { x: 500, y: 420 },
      { x: 600, y: 520 }, { x: 600, y: 750 }, { x: 500, y: 850 }
    ];

    // Gray Line path fractions
    // Total ≈ 1366: 300+233+350+233+250
    const grayStops = [0, 0.220, 0.390, 0.646, 0.817, 1.0];
    const grayCoords = [
      { x: 200, y: 280 }, { x: 500, y: 280 }, { x: 700, y: 160 },
      { x: 1050, y: 160 }, { x: 1250, y: 280 }, { x: 1500, y: 280 }
    ];

    const trainWhite: TrainState = {
      el: document.getElementById('train-white')!,
      trackId: 'track-white', passengerCount: 0, baseOpacity: 0.85
    };
    const trainGreen: TrainState = {
      el: document.getElementById('train-green')!,
      trackId: 'track-green', passengerCount: 0, baseOpacity: 0.70
    };
    const trainGray: TrainState = {
      el: document.getElementById('train-gray')!,
      trackId: 'track-gray', passengerCount: 0, baseOpacity: 0.60
    };

    runTrain(trainWhite, whiteStops, whiteCoords, 1000);
    runTrain(trainGreen, greenStops, greenCoords, 2500);
    runTrain(trainGray, grayStops, grayCoords, 4000);

    // ═══ HOVER SOUNDS ═══
    document.querySelectorAll('.mrt-station').forEach(el => {
      el.addEventListener('mouseenter', () => {
        if ((window as any).playBlip) (window as any).playBlip();
      });
    });

    // ═══ MOBILE TOUCH PAN + PINCH ZOOM ═══
    if (innerWidth < 768) {
      const wrapper = document.getElementById('mrt-pan-wrapper');
      const svgEl = document.getElementById('mrt-svg');
      if (wrapper && svgEl) {
        wrapper.style.pointerEvents = 'auto';
        wrapper.style.touchAction = 'none';
        wrapper.style.display = 'block';
        wrapper.style.position = 'relative';

        let px = -(svgEl.clientWidth - innerWidth) / 2;
        let py = -(svgEl.clientHeight - innerHeight) / 2;
        let scale = 1;
        let sx = 0, sy = 0, spx = 0, spy = 0;
        let initialDist = 0, initialScale = 1;

        const clamp = () => {
          const sw = svgEl.clientWidth * scale;
          const sh = svgEl.clientHeight * scale;
          px = Math.max(-(sw - innerWidth), Math.min(0, px));
          py = Math.max(-(sh - innerHeight), Math.min(0, py));
        };
        const apply = () => {
          svgEl.style.transform = `translate(${px}px,${py}px) scale(${scale})`;
          svgEl.style.transformOrigin = '0 0';
        };
        clamp(); apply();

        function getDist(touches: TouchList) {
          const dx = touches[0].clientX - touches[1].clientX;
          const dy = touches[0].clientY - touches[1].clientY;
          return Math.sqrt(dx * dx + dy * dy);
        }

        wrapper.addEventListener('touchstart', e => {
          if (e.touches.length === 2) {
            initialDist = getDist(e.touches);
            initialScale = scale;
          } else if (e.touches.length === 1) {
            sx = e.touches[0].clientX; sy = e.touches[0].clientY;
            spx = px; spy = py;
          }
        }, { passive: true });

        wrapper.addEventListener('touchmove', e => {
          if (e.touches.length === 2) {
            const dist = getDist(e.touches);
            scale = Math.max(0.5, Math.min(3.0, initialScale * (dist / initialDist)));
            clamp(); apply();
          } else if (e.touches.length === 1) {
            px = spx + (e.touches[0].clientX - sx);
            py = spy + (e.touches[0].clientY - sy);
            clamp(); apply();
          }
        }, { passive: true });
      }
    }

    // ═══ CLEANUP ═══
    document.addEventListener('astro:before-swap', () => {
      clearInterval(spawnInterval);
    }, { once: true });
  });
</script>
