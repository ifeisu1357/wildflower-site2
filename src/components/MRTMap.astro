---
// MRT Map — Mini Metro × WILDFLOWER
// 3 lines (blue/yellow/red), draw-in animation, always-visible labels
---

<div class="w-full h-screen relative overflow-hidden flex items-center justify-center pt-[20vh]" id="mrt-container">
  <svg
    id="mrt-svg"
    viewBox="-80 0 1400 750"
    class="w-full select-none mrt-svg-responsive"
    style="max-height: 75vh;"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid meet"
  >
    <!-- ═══ TRACKS ═══ -->

    <!-- Blue Line: 專案 → 商店 → 成員 -->
    <path id="track-blue"
      d="M 280,80 L 280,420 Q 280,460 320,460 L 560,460"
      fill="none" stroke="#3B7DD8" stroke-width="24"
      stroke-linecap="square" stroke-linejoin="miter" style="opacity:0"/>

    <!-- Yellow Line: 成員 → 活動 -->
    <path id="track-yellow"
      d="M 510,510 L 510,260 Q 510,220 550,220 L 780,220"
      fill="none" stroke="#E8B830" stroke-width="24"
      stroke-linecap="square" stroke-linejoin="miter" style="opacity:0"/>

    <!-- Red Line: 活動 → 追蹤 -->
    <path id="track-red"
      d="M 740,180 L 740,420 Q 740,460 780,460 L 1040,460"
      fill="none" stroke="#D44A33" stroke-width="24"
      stroke-linecap="square" stroke-linejoin="miter" style="opacity:0"/>

    <!-- ═══ T-SHAPED TERMINUS CAPS ═══ -->
    <g id="terminus-caps" style="opacity:0">
      <line x1="260" y1="80" x2="300" y2="80" stroke="#3B7DD8" stroke-width="8" stroke-linecap="square"/>
      <line x1="560" y1="440" x2="560" y2="480" stroke="#3B7DD8" stroke-width="8" stroke-linecap="square"/>
      <line x1="490" y1="510" x2="530" y2="510" stroke="#E8B830" stroke-width="8" stroke-linecap="square"/>
      <line x1="780" y1="200" x2="780" y2="240" stroke="#E8B830" stroke-width="8" stroke-linecap="square"/>
      <line x1="720" y1="180" x2="760" y2="180" stroke="#D44A33" stroke-width="8" stroke-linecap="square"/>
      <line x1="1040" y1="440" x2="1040" y2="480" stroke="#D44A33" stroke-width="8" stroke-linecap="square"/>
    </g>

    <!-- ═══ TRAINS ═══ -->
    <rect id="train-blue" x="-40" y="-18" width="80" height="36"
      fill="#3B7DD8" style="opacity:0"/>
    <rect id="train-yellow" x="-40" y="-18" width="80" height="36"
      fill="#E8B830" style="opacity:0"/>
    <rect id="train-red" x="-40" y="-18" width="80" height="36"
      fill="#D44A33" style="opacity:0"/>

    <!-- ═══ STATIONS ═══ -->

    <!-- 專案 (Blue top) -->
    <g class="mrt-station" data-station="projects" data-href="/projects">
      <rect class="station-hit" x="242" y="78" width="76" height="76" fill="transparent"/>
      <rect class="station-shape" x="262" y="98" width="36" height="36"
        fill="#09090b" stroke="#FFFFFF" stroke-width="5" style="opacity:0"/>
      <text class="station-label" x="320" y="124" text-anchor="start"
        fill="#FFFFFF" font-family="'IBM Plex Mono',monospace" font-size="26" font-weight="600"
        letter-spacing="0.1em" opacity="0">專案</text>
    </g>

    <!-- 商店 (Blue bend) -->
    <g class="mrt-station" data-station="store" data-href="https://shop.wild-flower.co" data-external="true">
      <rect class="station-hit" x="242" y="362" width="76" height="76" fill="transparent"/>
      <rect class="station-shape" x="262" y="382" width="36" height="36"
        fill="#09090b" stroke="#FFFFFF" stroke-width="5" style="opacity:0"/>
      <text class="station-label" x="240" y="408" text-anchor="end"
        fill="#FFFFFF" font-family="'IBM Plex Mono',monospace" font-size="26" font-weight="600"
        letter-spacing="0.1em" opacity="0">商店</text>
    </g>

    <!-- 成員 (Blue/Yellow transfer) — label top-left of square -->
    <g class="mrt-station" data-station="artists" data-href="/artists">
      <rect class="station-hit" x="472" y="422" width="76" height="76" fill="transparent"/>
      <rect class="station-shape" x="492" y="442" width="36" height="36"
        fill="#09090b" stroke="#FFFFFF" stroke-width="5" style="opacity:0"/>
      <rect class="label-bg" x="418" y="414" width="74" height="28" fill="#09090b" opacity="0"/>
      <text class="station-label" x="488" y="436" text-anchor="end"
        fill="#FFFFFF" font-family="'IBM Plex Mono',monospace" font-size="26" font-weight="600"
        letter-spacing="0.1em" opacity="0">成員</text>
    </g>

    <!-- 活動 (Yellow/Red transfer) — label top-right of square -->
    <g class="mrt-station" data-station="live" data-href="/live">
      <rect class="station-hit" x="702" y="182" width="76" height="76" fill="transparent"/>
      <rect class="station-shape" x="722" y="202" width="36" height="36"
        fill="#09090b" stroke="#FFFFFF" stroke-width="5" style="opacity:0"/>
      <rect class="label-bg" x="760" y="178" width="74" height="28" fill="#09090b" opacity="0"/>
      <text class="station-label" x="764" y="200" text-anchor="start"
        fill="#FFFFFF" font-family="'IBM Plex Mono',monospace" font-size="26" font-weight="600"
        letter-spacing="0.1em" opacity="0">活動</text>
    </g>

    <!-- 追蹤 (Red terminus) -->
    <g class="mrt-station" data-station="socials" data-href="https://www.instagram.com/wldflwrtw/" data-external="true">
      <rect class="station-hit" x="962" y="422" width="76" height="76" fill="transparent"/>
      <rect class="station-shape" x="982" y="442" width="36" height="36"
        fill="#09090b" stroke="#FFFFFF" stroke-width="5" style="opacity:0"/>
      <text class="station-label" x="1000" y="432" text-anchor="middle"
        fill="#FFFFFF" font-family="'IBM Plex Mono',monospace" font-size="26" font-weight="600"
        letter-spacing="0.1em" opacity="0">追蹤</text>
    </g>

    <!-- ═══ PASSENGER LAYER ═══ -->
    <g id="passenger-layer"></g>
  </svg>
</div>

<style>
  @media (max-width: 640px) {
    #mrt-container {
      align-items: center !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      justify-content: flex-start !important;
    }
    .mrt-svg-responsive {
      max-height: none !important;
      min-width: 700px;
      height: 85vh;
      padding: 0 1rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';
  gsap.registerPlugin(MotionPathPlugin);

  document.addEventListener('astro:page-load', () => {
    const container = document.getElementById('mrt-container');
    const svg = document.getElementById('mrt-svg');
    const passengerLayer = document.getElementById('passenger-layer');
    if (!svg || !passengerLayer || !container) return;
    const SVG_NS = 'http://www.w3.org/2000/svg';

    /* ═══ DRAW-IN ANIMATION ═══ */
    const tl = gsap.timeline();

    // 1. Draw track paths with stroke-dash animation
    const tracks = ['#track-blue', '#track-yellow', '#track-red'];
    tracks.forEach((sel, i) => {
      const path = document.querySelector(sel) as SVGPathElement;
      if (!path) return;
      const len = path.getTotalLength();
      gsap.set(path, { strokeDasharray: len, strokeDashoffset: len, opacity: 1 });
      tl.to(path, { strokeDashoffset: 0, duration: 1.0, ease: 'power2.inOut' }, 0.15 * i);
    });

    // 2. Terminus caps fade in
    tl.to('#terminus-caps', { opacity: 1, duration: 0.3, ease: 'power2.out' }, 0.8);

    // 3. Stations scale in
    const stationShapes = document.querySelectorAll('.station-shape');
    stationShapes.forEach((s, i) => {
      const bbox = (s as SVGRectElement).getBBox();
      const cx = bbox.x + bbox.width / 2;
      const cy = bbox.y + bbox.height / 2;
      gsap.set(s, { scale: 0, svgOrigin: `${cx} ${cy}`, opacity: 1 });
      tl.to(s, { scale: 1, duration: 0.4, ease: 'back.out(1.7)' }, 1.0 + i * 0.12);
    });

    // 4. Label backgrounds + labels fade in
    const labelBgs = document.querySelectorAll('.label-bg');
    const labels = document.querySelectorAll('.station-label');
    labelBgs.forEach((bg) => {
      tl.to(bg, { opacity: 1, duration: 0.3, ease: 'power2.out' }, 1.4);
    });
    labels.forEach((lbl, i) => {
      tl.to(lbl, { opacity: 1, duration: 0.3, ease: 'power2.out' }, 1.4 + i * 0.1);
    });

    // 5. Trains fade in last
    tl.to('#train-blue', { opacity: 1, duration: 0.5 }, 2.0);
    tl.to('#train-yellow', { opacity: 1, duration: 0.5 }, 2.2);
    tl.to('#train-red', { opacity: 1, duration: 0.5 }, 2.4);

    /* ═══ STATION DATA ═══ */
    interface StationData {
      id: string; x: number; y: number;
      queue: SVGCircleElement[]; dests: string[];
      qx: number; qy: number;
    }

    const stationMap: Record<string, StationData> = {
      projects: { id: 'projects', x: 280, y: 116,  queue: [], dests: [], qx: -1, qy: 0 },
      store:    { id: 'store',    x: 280, y: 400,  queue: [], dests: [], qx: 1, qy: 0 },
      artists:  { id: 'artists',  x: 510, y: 460,  queue: [], dests: [], qx: 1, qy: 1 },
      live:     { id: 'live',     x: 740, y: 220,  queue: [], dests: [], qx: 0, qy: 1 },
      socials:  { id: 'socials',  x: 1000, y: 460, queue: [], dests: [], qx: 1, qy: 1 },
    };

    const stationIds = Object.keys(stationMap);
    const MAX_QUEUE = 6;
    const TRAIN_CAPACITY = 4;
    const P_RADIUS = 5;

    /* ═══ PASSENGER HELPERS ═══ */
    function createPassenger(cx: number, cy: number): SVGCircleElement {
      const c = document.createElementNS(SVG_NS, 'circle');
      c.setAttribute('cx', String(cx));
      c.setAttribute('cy', String(cy));
      c.setAttribute('r', String(P_RADIUS));
      c.setAttribute('fill', '#FFFFFF');
      c.setAttribute('opacity', '0');
      return c;
    }

    function queuePos(station: StationData, idx: number) {
      const offset = 30 + idx * 12;
      const mag = Math.sqrt(station.qx * station.qx + station.qy * station.qy) || 1;
      return {
        x: station.x + (station.qx / mag) * offset,
        y: station.y + (station.qy / mag) * offset,
      };
    }

    function spawnPassenger() {
      const id = stationIds[Math.floor(Math.random() * stationIds.length)];
      const station = stationMap[id];
      if (station.queue.length >= MAX_QUEUE) return;

      let dest = id;
      while (dest === id) dest = stationIds[Math.floor(Math.random() * stationIds.length)];

      const pos = queuePos(station, station.queue.length);
      const circle = createPassenger(pos.x, pos.y);
      passengerLayer.appendChild(circle);

      gsap.to(circle, { attr: { opacity: 0.8 }, duration: 0.4 });
      gsap.to(circle, {
        attr: { cx: pos.x + (station.qx || 0) * 2, cy: pos.y + (station.qy || 0) * 2 },
        duration: 1.0 + Math.random() * 0.6,
        ease: 'sine.inOut', yoyo: true, repeat: -1,
      });

      station.queue.push(circle);
      station.dests.push(dest);
    }

    // Delay passenger spawning until draw-in completes
    setTimeout(() => {
      for (let i = 0; i < 12; i++) setTimeout(spawnPassenger, i * 180);
    }, 2600);
    const spawnInterval = setInterval(spawnPassenger, 2200);

    function reindexQueue(station: StationData) {
      station.queue.forEach((c, idx) => {
        const pos = queuePos(station, idx);
        gsap.to(c, { attr: { cx: pos.x, cy: pos.y }, duration: 0.3, ease: 'power2.out' });
      });
    }

    /* ═══ BOARDING & DISEMBARKING ═══ */
    function boardPassengers(train: TrainState, stationId: string) {
      const station = stationMap[stationId];
      if (!station) return;
      const toBoard = Math.min(TRAIN_CAPACITY - train.passengers.length, station.queue.length);
      for (let i = 0; i < toBoard; i++) {
        const circle = station.queue.shift()!;
        const dest = station.dests.shift()!;
        train.passengers.push(dest);
        gsap.killTweensOf(circle);
        gsap.to(circle, {
          attr: { cx: station.x, cy: station.y },
          duration: 0.25, delay: i * 0.1, ease: 'power2.in',
        });
        gsap.to(circle, {
          attr: { r: 0, opacity: 0 },
          duration: 0.2, delay: 0.25 + i * 0.1, ease: 'power2.in',
          onComplete: () => circle.remove(),
        });
      }
      reindexQueue(station);
    }

    function disembarkPassengers(train: TrainState, stationId: string) {
      const station = stationMap[stationId];
      if (!station) return;
      const staying: string[] = [];
      const leaving: string[] = [];
      for (const dest of train.passengers) {
        if (dest === stationId) leaving.push(dest);
        else staying.push(dest);
      }
      train.passengers = staying;

      for (let i = 0; i < leaving.length; i++) {
        const angle = (Math.random() - 0.5) * Math.PI * 1.2;
        const dist = 30 + Math.random() * 40;
        const circle = createPassenger(station.x, station.y);
        circle.setAttribute('r', '0');
        passengerLayer.appendChild(circle);
        gsap.to(circle, {
          attr: {
            cx: station.x + Math.cos(angle) * dist,
            cy: station.y + Math.sin(angle) * dist,
            r: P_RADIUS, opacity: 0.6,
          },
          duration: 0.4, delay: i * 0.08, ease: 'back.out(1.5)',
        });
        gsap.to(circle, {
          attr: { opacity: 0, r: 0 },
          duration: 0.5, delay: 1.5 + i * 0.08,
          ease: 'power2.in', onComplete: () => circle.remove(),
        });
      }
    }

    /* ═══ TRAIN STATE & MOVEMENT ═══ */
    interface TrainState {
      el: HTMLElement; trackId: string; passengers: string[];
      stops: number[]; stationIds: string[];
      currentStop: number; direction: 1 | -1;
    }

    function advanceTrain(train: TrainState) {
      const next = train.currentStop + train.direction;
      if (next < 0 || next >= train.stops.length) {
        train.direction *= -1 as 1 | -1;
        setTimeout(() => advanceTrain(train), 500);
        return;
      }
      const trackSel = `#${train.trackId}`;
      const dist = Math.abs(train.stops[next] - train.stops[train.currentStop]);
      gsap.to(train.el, {
        duration: Math.max(dist * 7, 0.8),
        motionPath: {
          path: trackSel, align: trackSel,
          alignOrigin: [0.5, 0.5], autoRotate: true,
          start: train.stops[train.currentStop], end: train.stops[next],
        },
        ease: 'power2.inOut',
        onComplete: () => {
          train.currentStop = next;
          const sid = train.stationIds[next];
          if (sid) dwell(train, sid);
          else setTimeout(() => advanceTrain(train), 100);
        },
      });
    }

    function dwell(train: TrainState, stationId: string) {
      disembarkPassengers(train, stationId);
      setTimeout(() => {
        boardPassengers(train, stationId);
        setTimeout(() => advanceTrain(train), 900);
      }, 500);
    }

    function initTrain(train: TrainState, delay: number) {
      const trackSel = `#${train.trackId}`;
      if (!document.querySelector(trackSel)) return;
      gsap.set(train.el, {
        motionPath: { path: trackSel, align: trackSel,
          alignOrigin: [0.5, 0.5], autoRotate: true,
          start: train.stops[0], end: train.stops[0] },
      });
      setTimeout(() => advanceTrain(train), delay);
    }

    /* ═══ TRAIN CONFIGS ═══ */
    const trainBlue: TrainState = {
      el: document.getElementById('train-blue')!,
      trackId: 'track-blue', passengers: [],
      stops: [0.056, 0.498, 0.922],
      stationIds: ['projects', 'store', 'artists'],
      currentStop: 0, direction: 1,
    };

    const trainYellow: TrainState = {
      el: document.getElementById('train-yellow')!,
      trackId: 'track-yellow', passengers: [],
      stops: [0.092, 0.926],
      stationIds: ['artists', 'live'],
      currentStop: 0, direction: 1,
    };

    const trainRed: TrainState = {
      el: document.getElementById('train-red')!,
      trackId: 'track-red', passengers: [],
      stops: [0.071, 0.929],
      stationIds: ['live', 'socials'],
      currentStop: 0, direction: 1,
    };

    setTimeout(() => {
      initTrain(trainBlue, 0);
      initTrain(trainYellow, 400);
      initTrain(trainRed, 800);
    }, 2600);

    /* ═══ STATION HOVER — scale shape + label size bump animation ═══ */
    document.querySelectorAll('.mrt-station').forEach((el) => {
      const shape = el.querySelector('.station-shape') as SVGElement;
      const label = el.querySelector('.station-label') as SVGTextElement;
      if (!shape) return;

      const bbox = shape.getBBox();
      const cx = bbox.x + bbox.width / 2;
      const cy = bbox.y + bbox.height / 2;

      el.addEventListener('mouseenter', () => {
        gsap.to(shape, {
          scale: 1.25,
          svgOrigin: `${cx} ${cy}`,
          duration: 0.25, ease: 'back.out(1.5)',
        });
        if (label) {
          gsap.to(label, {
            attr: { 'font-size': 32 },
            duration: 0.2, ease: 'power2.out',
          });
        }
      });

      el.addEventListener('mouseleave', () => {
        gsap.to(shape, { scale: 1, svgOrigin: `${cx} ${cy}`, duration: 0.3, ease: 'power2.in' });
        if (label) {
          gsap.to(label, {
            attr: { 'font-size': 26 },
            duration: 0.25, ease: 'power2.in',
          });
        }
      });

      el.addEventListener('click', () => {
        const href = el.getAttribute('data-href');
        const external = el.getAttribute('data-external');
        if (!href) return;
        if (external === 'true') window.open(href, '_blank', 'noopener');
        else window.location.href = href;
      });

      (el as HTMLElement).style.cursor = 'pointer';
    });

    document.addEventListener('astro:before-swap', () => { clearInterval(spawnInterval); }, { once: true });
  });
</script>
