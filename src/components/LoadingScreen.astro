---
// Loading Screen: 野花 logo top-left, counter → "enter" center, pixelated font
---
<div class="loading-screen" id="loading-screen">
  <!-- Logo top-left -->
  <div class="fixed top-0 left-0 p-4 md:p-6 z-[100001]">
    <span class="text-base md:text-lg text-wf-white" style="font-family: 'Noto Sans TC', sans-serif; font-weight: 900; letter-spacing: 0.08em;">野花</span>
  </div>

  <!-- Center: counter → enter -->
  <div class="text-center">
    <span class="loading-counter font-pixel" id="loading-counter">0</span>
    <a href="#" class="enter-link font-pixel hidden" id="enter-link">enter</a>
  </div>
</div>

<script>
  const screen = document.getElementById('loading-screen')!;
  const counter = document.getElementById('loading-counter')!;
  const enterLink = document.getElementById('enter-link')!;

  if (sessionStorage.getItem('wf-entered') === '1') {
    screen.style.display = 'none';
  } else {
    const duration = 2400;
    const startTime = performance.now();

    function animateCounter(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const count = Math.floor(eased * 100);
      counter.textContent = count + '%';

      if (progress < 1) {
        requestAnimationFrame(animateCounter);
      } else {
        counter.textContent = '100%';
        setTimeout(() => {
          counter.style.transition = 'opacity 0.6s ease';
          counter.style.opacity = '0';
          setTimeout(() => {
            counter.classList.add('hidden');
            enterLink.classList.remove('hidden');
            requestAnimationFrame(() => { enterLink.style.opacity = '1'; });
          }, 600);
        }, 400);
      }
    }

    requestAnimationFrame(animateCounter);

    enterLink.addEventListener('click', (e) => {
      e.preventDefault();
      sessionStorage.setItem('wf-entered', '1');
      window.dispatchEvent(new CustomEvent('wf:enter'));
      screen.style.transition = 'opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
      screen.style.opacity = '0';
      setTimeout(() => { screen.style.display = 'none'; }, 800);
    });
  }
</script>
