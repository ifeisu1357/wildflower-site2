---
// Custom Cursor: 4px square dot, mix-blend-mode: exclusion
// Rotates 45° to diamond on hover
---

<div class="cursor-dot" id="cursor-dot"></div>

<script>
  document.addEventListener('astro:page-load', () => {
    const dot = document.getElementById('cursor-dot');
    if (!dot || 'ontouchstart' in window) {
      if (dot) dot.style.display = 'none';
      return;
    }

    let mouseX = 0, mouseY = 0;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      dot.style.transform = `translate(${mouseX - 2}px, ${mouseY - 2}px)`;
    });

    const hoverTargets = 'a, button, [data-clickable], .mrt-station';

    document.addEventListener('mouseover', (e) => {
      if ((e.target as Element).closest(hoverTargets)) {
        dot.classList.add('hovering');
      }
    });

    document.addEventListener('mouseout', (e) => {
      if ((e.target as Element).closest(hoverTargets)) {
        dot.classList.remove('hovering');
      }
    });

    document.addEventListener('mouseleave', () => { dot.style.opacity = '0'; });
    document.addEventListener('mouseenter', () => { dot.style.opacity = '1'; });
  });
</script>
