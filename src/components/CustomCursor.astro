---
// Custom Cursor: 12px white circle, expands on hover
---

<div class="cursor-dot" id="cursor-dot"></div>

<script>
  document.addEventListener('astro:page-load', () => {
    const dot = document.getElementById('cursor-dot');
    if (!dot || 'ontouchstart' in window) {
      if (dot) dot.style.display = 'none';
      return;
    }

    document.addEventListener('mousemove', (e) => {
      dot.style.transform = `translate(${e.clientX}px, ${e.clientY}px)`;
    });

    const hoverTargets = 'a, button, [data-clickable], .mrt-station';

    document.addEventListener('mouseover', (e) => {
      if ((e.target as Element).closest(hoverTargets)) dot.classList.add('hovering');
    });
    document.addEventListener('mouseout', (e) => {
      if ((e.target as Element).closest(hoverTargets)) dot.classList.remove('hovering');
    });

    document.addEventListener('mouseleave', () => { dot.style.opacity = '0'; });
    document.addEventListener('mouseenter', () => { dot.style.opacity = '1'; });
  });
</script>
