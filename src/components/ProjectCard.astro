---
interface Props {
  title: string;
  artist: string;
  cover: string;
  type: string;
  year: number;
  releaseDate?: string;
  published: boolean;
}

const { title, artist, cover, type, year, releaseDate, published } = Astro.props;

const isUpcoming = releaseDate ? new Date(releaseDate) > new Date() : false;
const showCountdown = !published || isUpcoming;
---

<div class="project-card bg-wf-gray" data-release-date={releaseDate || ''} data-published={String(published)}>
  <img
    src={cover || ''}
    alt={published ? title : ''}
    class:list={[
      'w-full h-full object-cover',
      showCountdown ? 'opacity-20 blur-[3px]' : 'opacity-100',
    ]}
    loading="lazy"
  />

  {showCountdown ? (
    <div class="countdown-overlay">
      <div class="text-center px-2">
        <div class="font-display text-[10px] md:text-xs tracking-[0.2em] text-wf-light/50 mb-1">即將發行</div>
        {releaseDate && (
          <div class="countdown-timer font-mono text-xs md:text-sm tracking-wider text-wf-white/80" data-date={releaseDate}></div>
        )}
      </div>
    </div>
  ) : (
    <div class="overlay text-center">
      <h3 class="font-display text-sm md:text-base font-bold text-wf-white mb-1">{title}</h3>
      <p class="font-display text-[9px] md:text-[10px] tracking-[0.15em] text-wf-light/50">{artist}</p>
      <p class="font-display text-[9px] md:text-[10px] tracking-[0.1em] text-wf-light/30 mt-1">{type} · {year}</p>
    </div>
  )}
</div>
