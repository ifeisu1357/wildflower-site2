---
interface Props {
  slug: string;
  name: string;
  tag: string;
  photo?: string;
}

const { slug, name, tag, photo } = Astro.props;
---

<a
  href={`/artists/${slug}`}
  class="group relative block py-6 md:py-10 transition-all duration-700 hover:opacity-80"
  data-clickable
>
  <!-- Full-bleed photo fades in on hover -->
  {photo && (
    <div class="absolute inset-0 overflow-hidden opacity-0 group-hover:opacity-[0.12] transition-opacity duration-700 pointer-events-none">
      <img src={photo} alt="" class="w-full h-full object-cover" loading="lazy" />
    </div>
  )}

  <!-- Massive editorial typography -->
  <div class="relative z-10">
    <h2 class="font-display text-[3rem] md:text-[5rem] lg:text-[7rem] font-black leading-[0.85] text-wf-white tracking-tight">
      {name}
    </h2>
    <p class="font-mono text-[10px] md:text-xs tracking-[0.3em] text-wf-light/30 mt-3 uppercase">
      {tag}
    </p>
  </div>
</a>
