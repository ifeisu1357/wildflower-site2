---
interface Props {
  slug: string;
  name: string;
  nameEn?: string;
  tag: string;
  photo?: string;
}

const { slug, name, nameEn, tag, photo } = Astro.props;
---

<a
  href={`/artists/${slug}`}
  class="group block border border-wf-mid/30 p-4 md:p-6 transition-all duration-500 hover:border-wf-light/20 hover:bg-wf-gray/30"
  data-clickable
>
  <div class="flex items-start gap-4">
    <div class="w-16 h-16 md:w-20 md:h-20 flex-shrink-0 bg-wf-gray border border-wf-mid/20 flex items-center justify-center overflow-hidden">
      {photo ? (
        <img src={photo} alt={name} class="w-full h-full object-cover" />
      ) : (
        <span class="text-wf-mid text-xs font-mono">—</span>
      )}
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="font-display text-base md:text-lg text-wf-white group-hover:text-wf-white/90 transition-colors duration-300">
        {name}
      </h3>
      {nameEn && (
        <p class="font-mono text-[10px] tracking-[0.2em] text-wf-light/40 mt-0.5 uppercase">
          {nameEn}
        </p>
      )}
      <p class="font-mono text-[11px] text-wf-light/40 mt-2 tracking-wider">
        {tag}
      </p>
    </div>
    <span class="font-display text-sm text-wf-mid group-hover:text-wf-light/40 transition-colors duration-500 mt-1">
      →
    </span>
  </div>
</a>
