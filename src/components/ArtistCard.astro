---
interface Props {
  slug: string;
  name: string;
  tag: string;
  photo?: string;
}

const { slug, name, tag, photo } = Astro.props;
---

<a
  href={`/artists/${slug}`}
  class="group flex items-center gap-4 py-4 transition-all duration-300 hover:opacity-70"
  data-clickable
>
  <div class="w-10 h-10 md:w-12 md:h-12 flex-shrink-0 bg-wf-gray flex items-center justify-center overflow-hidden">
    {photo ? (
      <img src={photo} alt={name} class="w-full h-full object-cover" />
    ) : (
      <span class="text-wf-mid text-xs font-display">—</span>
    )}
  </div>

  <div class="flex-1 min-w-0">
    <h3 class="font-display text-base text-wf-white tracking-wide">{name}</h3>
    <p class="font-display text-xs text-wf-light/35 mt-0.5 tracking-wider">{tag}</p>
  </div>
</a>
