---
interface ArtistLink {
  slug: string;
  name: string;
}

interface Props {
  artists: ArtistLink[];
  currentSlug: string;
}

const { artists, currentSlug } = Astro.props;
---

<nav class="space-y-1">
  <a
    href="/artists"
    class="block font-display text-sm text-wf-light/40 hover:text-wf-light/70 transition-colors duration-300 mb-6"
    data-clickable
  >
    ←
  </a>
  {artists.map((artist) => (
    <a
      href={`/artists/${artist.slug}`}
      class:list={[
        'block py-2 px-3 font-display text-sm transition-all duration-300 border-l',
        artist.slug === currentSlug
          ? 'border-wf-white text-wf-white'
          : 'border-transparent text-wf-light/40 hover:text-wf-light/70 hover:border-wf-mid',
      ]}
      data-clickable
    >
      {artist.name}
    </a>
  ))}
</nav>
