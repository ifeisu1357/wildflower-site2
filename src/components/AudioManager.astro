---
// Audio Manager: ambient drone on enter, tick on hover, thud on nav
---

<audio id="bg-audio" src="/audio/background.mp3" loop preload="auto"></audio>
<audio id="sfx-blip" src="/sounds/blip.mp3" preload="auto"></audio>
<audio id="sfx-click" src="/sounds/click.mp3" preload="auto"></audio>

<script>
  document.addEventListener('astro:page-load', () => {
    const bg = document.getElementById('bg-audio') as HTMLAudioElement;
    const blip = document.getElementById('sfx-blip') as HTMLAudioElement;
    const click = document.getElementById('sfx-click') as HTMLAudioElement;

    if (bg) bg.volume = 0.08;
    if (blip) blip.volume = 0.06;
    if (click) click.volume = 0.08;

    // Start bg on enter
    function startAudio() {
      if (bg && bg.paused) {
        bg.play().catch(() => {});
      }
    }

    // If already entered
    if (sessionStorage.getItem('wf-entered') === '1') {
      startAudio();
    }

    window.addEventListener('wf:enter', startAudio);

    // Global sound functions
    (window as any).playBlip = () => {
      if (blip) {
        blip.currentTime = 0;
        blip.play().catch(() => {});
      }
    };

    (window as any).playClick = () => {
      if (click) {
        click.currentTime = 0;
        click.play().catch(() => {});
      }
    };
  });
</script>
