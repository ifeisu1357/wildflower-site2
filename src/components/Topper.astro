---
const isHome = Astro.url.pathname === '/';
---

<header class="fixed top-0 left-0 w-full z-[9999] topper-header">
  <a href="/" class:list={["topper-link", { "topper-home": isHome }]}>WILDFLOWER</a>
</header>

<style>
  .topper-header {
    padding: 24px 60px;
  }

  .topper-link {
    font-family: 'Unbounded', sans-serif;
    font-weight: 900;
    font-size: 10px;
    letter-spacing: 0.22em;
    color: #E8E4DE;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .topper-link:hover {
    opacity: 0.5;
  }

  .topper-home {
    font-size: 14px;
    color: #FFFFFF;
  }

  @media (max-width: 640px) {
    .topper-header {
      padding: 16px 20px;
    }

    .topper-link {
      font-size: 9px;
    }

    .topper-home {
      font-size: 11px;
    }
  }
</style>
