---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArtists } from '../../lib/data';

export function getStaticPaths() {
  const artists = getArtists();
  return artists.map((artist) => ({
    params: { slug: artist.slug },
    props: { artist },
  }));
}

const { artist } = Astro.props;
const photo = artist.photo;
const links = artist.links;
---

<BaseLayout title={`${artist.name} — WILDFLOWER`}>
  <main class="artist-page">
    <div class="artist-layout">
      <!-- Left: Photo + Links -->
      <div class="artist-left">
        <div class="artist-photo-wrap">
          {photo ? (
            <img src={photo} alt={artist.name} class="artist-photo" />
          ) : (
            <div class="artist-photo-empty"></div>
          )}
        </div>

        {links && (
          <div class="artist-links">
            {links.instagram && <a href={links.instagram} target="_blank" rel="noopener">IG</a>}
            {links.spotify && <a href={links.spotify} target="_blank" rel="noopener">SP</a>}
            {links.appleMusic && <a href={links.appleMusic} target="_blank" rel="noopener">AM</a>}
            {links.website && <a href={links.website} target="_blank" rel="noopener">WEB</a>}
          </div>
        )}
      </div>

      <!-- Right: Name + Tag + Bio -->
      <div class="artist-right">
        <h1 class="artist-name">{artist.name}</h1>
        <div class="artist-tag-line">{artist.tag}</div>

        {artist.bio && (
          <div class="artist-bio">
            <p>{artist.bio}</p>
          </div>
        )}

        <div class="artist-quote">
          <span class="quote-dash">—</span>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .artist-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 10;
    padding: 6rem 3.5rem 4rem;
  }

  .artist-layout {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
    max-width: 720px;
  }

  /* ═══ LEFT COLUMN ═══ */
  .artist-left {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  .artist-photo-wrap {
    width: 200px;
    height: 260px;
    overflow: hidden;
    background: #18181b;
    position: relative;
  }

  .artist-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.5) contrast(1.1);
    transition: filter 0.5s ease;
  }

  .artist-photo-wrap:hover .artist-photo {
    filter: grayscale(0) contrast(1);
  }

  .artist-photo-empty {
    width: 100%;
    height: 100%;
    background: #18181b;
  }

  .artist-links {
    display: flex;
    gap: 1.2rem;
  }

  .artist-links a {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 400;
    font-size: 9px;
    color: #3f3f46;
    text-decoration: none;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }

  .artist-links a:hover {
    color: #E8E4DE;
  }

  /* ═══ RIGHT COLUMN ═══ */
  .artist-right {
    flex: 1;
    padding-top: 0.5rem;
  }

  .artist-name {
    font-family: 'Noto Serif TC', serif;
    font-weight: 700;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #E8E4DE;
    line-height: 1;
    letter-spacing: 0.02em;
    margin-bottom: 0.6rem;
  }

  .artist-tag-line {
    font-family: 'Unbounded', sans-serif;
    font-weight: 200;
    font-size: 8px;
    color: rgba(230, 230, 230, 0.2);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(39, 39, 42, 0.25);
  }

  .artist-bio {
    font-family: 'Noto Serif TC', serif;
    font-weight: 300;
    font-size: 13px;
    line-height: 2.2;
    color: rgba(230, 230, 230, 0.3);
    letter-spacing: 0.04em;
    margin-bottom: 2rem;
  }

  .artist-quote {
    margin-top: 1rem;
  }

  .quote-dash {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: #27272a;
  }

  /* ═══ MOBILE ═══ */
  @media (max-width: 640px) {
    .artist-page {
      padding: 5rem 1.5rem 12rem;
      align-items: center;
      justify-content: center;
    }

    .artist-layout {
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
      text-align: center;
    }

    .artist-left {
      align-items: center;
    }

    .artist-photo-wrap {
      width: 120px;
      height: 155px;
    }

    .artist-right {
      padding-top: 0;
    }

    .artist-name {
      font-size: clamp(1.8rem, 8vw, 2.5rem);
    }

    .artist-tag-line {
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
    }
  }
</style>
