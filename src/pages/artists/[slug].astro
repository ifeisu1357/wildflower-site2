---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const artists = await getCollection('artists');
  return artists.map((artist) => ({
    params: { slug: artist.slug },
    props: { artist },
  }));
}

interface Props {
  artist: CollectionEntry<'artists'>;
}

const { artist } = Astro.props;
const { Content } = await artist.render();
const photo = artist.data.photo;
const links = artist.data.links;
---

<BaseLayout title={`${artist.data.name} — WILDFLOWER`}>
  <!-- Hero photo background -->
  {photo && (
    <div class="artist-hero" style={`background-image: url(${photo})`}></div>
  )}

  <main class="min-h-screen pt-32 pb-20 px-5 md:px-10 relative z-10">
    <div class="max-w-3xl">
      <!-- Profile photo -->
      {photo && (
        <div class="artist-photo-wrap">
          <img src={photo} alt={artist.data.name} class="artist-photo" />
        </div>
      )}

      <h1 class="artist-title">{artist.data.name}</h1>
      <p class="artist-role">{artist.data.tag}</p>

      {links && (
        <div class="artist-links">
          {links.instagram && <a href={links.instagram} target="_blank" rel="noopener">Instagram</a>}
          {links.spotify && <a href={links.spotify} target="_blank" rel="noopener">Spotify</a>}
          {links.appleMusic && <a href={links.appleMusic} target="_blank" rel="noopener">Apple Music</a>}
          {links.website && <a href={links.website} target="_blank" rel="noopener">Website</a>}
        </div>
      )}

      <div class="artist-body">
        <Content />
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .artist-hero {
    position: fixed;
    inset: 0;
    z-index: 1;
    background-size: cover;
    background-position: center;
    opacity: 0.15;
    filter: grayscale(0.5);
  }

  .artist-photo-wrap {
    width: 120px;
    height: 120px;
    overflow: hidden;
    margin-bottom: 2rem;
    border: 1px solid rgba(232, 228, 222, 0.1);
  }

  .artist-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.3);
  }

  .artist-title {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 8rem);
    line-height: 0.95;
    color: #E8E4DE;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .artist-role {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 12px;
    color: #71717a;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .artist-links {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .artist-links a {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 400;
    font-size: 11px;
    color: #E8E4DE;
    text-decoration: none;
    letter-spacing: 0.08em;
    opacity: 0.4;
  }

  .artist-links a:hover {
    opacity: 1;
  }

  .artist-body {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 14px;
    line-height: 1.8;
    color: #71717a;
  }

  .artist-body :global(p) {
    margin-bottom: 1rem;
  }
</style>
