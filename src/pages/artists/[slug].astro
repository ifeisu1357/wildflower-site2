---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const artists = await getCollection('artists');
  return artists.map((artist) => ({
    params: { slug: artist.slug },
    props: { artist },
  }));
}

interface Props {
  artist: CollectionEntry<'artists'>;
}

const { artist } = Astro.props;
const { Content } = await artist.render();
const photo = artist.data.photo;
const links = artist.data.links;
---

<BaseLayout title={`${artist.data.name} — WILDFLOWER`}>
  <main class="min-h-screen pt-28 pb-20 px-5 md:px-12 relative z-10">
    <div class="artist-detail">
      <div class="artist-left">
        <!-- Profile photo -->
        <div class="artist-photo-wrap">
          {photo ? (
            <img src={photo} alt={artist.data.name} class="artist-photo" />
          ) : (
            <div class="artist-photo-empty"></div>
          )}
        </div>

        {links && (
          <div class="artist-links">
            {links.instagram && <a href={links.instagram} target="_blank" rel="noopener">IG</a>}
            {links.spotify && <a href={links.spotify} target="_blank" rel="noopener">SP</a>}
            {links.appleMusic && <a href={links.appleMusic} target="_blank" rel="noopener">AM</a>}
            {links.website && <a href={links.website} target="_blank" rel="noopener">WEB</a>}
          </div>
        )}
      </div>

      <div class="artist-right">
        <h1 class="artist-title">{artist.data.name}</h1>
        <p class="artist-role">{artist.data.tag}</p>

        <div class="artist-bio">
          <Content />
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .artist-detail {
    display: flex;
    gap: 3rem;
    max-width: 800px;
    align-items: flex-start;
  }

  .artist-left {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .artist-photo-wrap {
    width: 180px;
    height: 180px;
    overflow: hidden;
    background: #18181b;
  }

  .artist-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.3);
  }

  .artist-photo-empty {
    width: 100%;
    height: 100%;
    background: #18181b;
  }

  .artist-links {
    display: flex;
    gap: 1rem;
  }

  .artist-links a {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 400;
    font-size: 10px;
    color: #52525b;
    text-decoration: none;
    letter-spacing: 0.12em;
    transition: color 0.3s ease;
  }

  .artist-links a:hover {
    color: #E8E4DE;
    opacity: 1;
  }

  .artist-right {
    flex: 1;
    padding-top: 0.5rem;
  }

  .artist-title {
    font-family: 'Noto Serif TC', serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1;
    color: #E8E4DE;
    letter-spacing: 0.02em;
    margin-bottom: 0.5rem;
  }

  .artist-role {
    font-family: 'Unbounded', sans-serif;
    font-weight: 200;
    font-size: 7px;
    color: rgba(230, 230, 230, 0.22);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .artist-bio {
    font-family: 'Noto Serif TC', serif;
    font-weight: 300;
    font-size: 12px;
    line-height: 2;
    color: rgba(230, 230, 230, 0.3);
    letter-spacing: 0.04em;
  }

  .artist-bio :global(p) {
    margin-bottom: 1rem;
  }

  @media (max-width: 640px) {
    .artist-detail {
      flex-direction: column;
      gap: 1.5rem;
    }

    .artist-photo-wrap {
      width: 140px;
      height: 140px;
    }
  }
</style>
