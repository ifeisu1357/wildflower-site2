---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const artists = await getCollection('artists');
  return artists.map((artist) => ({
    params: { slug: artist.slug },
    props: { artist },
  }));
}

const { artist } = Astro.props;
const { Content } = await artist.render();
const { name, tag, photo, links } = artist.data;
---

<BaseLayout title={`${name} — WILDFLOWER野花`} description={`${name} — ${tag}`}>
  <!-- Full-screen hero -->
  <section class="relative min-h-screen flex items-end">
    <!-- Background photo -->
    {photo && (
      <div class="absolute inset-0">
        <img src={photo} alt={name} class="w-full h-full object-cover opacity-25" />
        <div class="absolute inset-0 bg-gradient-to-t from-wf-black via-wf-black/60 to-transparent"></div>
      </div>
    )}

    <!-- Back button -->
    <a href="/artists" class="fixed top-6 left-6 md:left-12 z-20 font-mono text-[10px] tracking-[0.3em] text-wf-light/40 hover:text-wf-light/70 transition-colors duration-500 uppercase" data-clickable>
      ←
    </a>

    <!-- Hero content -->
    <div class="relative z-10 w-full px-6 md:px-12 lg:px-24 pb-12 md:pb-20">
      <h1 class="font-display text-[4rem] md:text-[8rem] lg:text-[12rem] font-black leading-[0.82] text-wf-white tracking-tight mb-4">
        {name}
      </h1>
      <p class="font-mono text-xs md:text-sm tracking-[0.3em] text-wf-light/40 uppercase mb-6">
        {tag}
      </p>

      <!-- Links: Space Mono, minimal -->
      <div class="flex gap-6">
        {links.instagram && (
          <a href={links.instagram} target="_blank" rel="noopener" class="font-mono text-[10px] tracking-[0.2em] text-wf-light/35 hover:text-wf-white transition-colors duration-500 uppercase" data-clickable>
            IG
          </a>
        )}
        {links.spotify && (
          <a href={links.spotify} target="_blank" rel="noopener" class="font-mono text-[10px] tracking-[0.2em] text-wf-light/35 hover:text-wf-white transition-colors duration-500 uppercase" data-clickable>
            Spotify
          </a>
        )}
        {links.appleMusic && (
          <a href={links.appleMusic} target="_blank" rel="noopener" class="font-mono text-[10px] tracking-[0.2em] text-wf-light/35 hover:text-wf-white transition-colors duration-500 uppercase" data-clickable>
            Apple Music
          </a>
        )}
        {links.website && (
          <a href={links.website} target="_blank" rel="noopener" class="font-mono text-[10px] tracking-[0.2em] text-wf-light/35 hover:text-wf-white transition-colors duration-500 uppercase" data-clickable>
            Web
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- Bio: scrolls below the fold -->
  <section class="px-6 md:px-12 lg:px-24 py-16 md:py-24 max-w-3xl">
    <div class="prose prose-invert prose-sm max-w-none font-display text-wf-light/50 leading-relaxed text-sm md:text-base">
      <Content />
    </div>
  </section>
</BaseLayout>
