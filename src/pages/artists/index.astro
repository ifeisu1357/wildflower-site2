---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const artists = (await getCollection('artists')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="ARTISTS — WILDFLOWER">
  <main class="min-h-screen pt-24 pb-16 px-5 md:px-10">
    <div class="artist-list">
      {artists.map((artist) => {
        const displayName = artist.data.nameEn || artist.data.name;
        const photo = artist.data.photo;
        return (
          <a
            href={`/artists/${artist.slug}`}
            class="artist-row"
            data-photo={photo || ''}
          >
            <span class="artist-name">{displayName}</span>
            <span class="artist-tag">{artist.data.tag}</span>
          </a>
        );
      })}
    </div>

    <!-- Fullscreen photo backdrop -->
    <div class="artist-backdrop" id="artist-backdrop"></div>
  </main>
</BaseLayout>

<style>
  .artist-list {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .artist-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    text-decoration: none;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(39, 39, 42, 0.5);
    transition: opacity 0.4s ease;
  }

  .artist-name {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 700;
    font-size: clamp(3rem, 10vw, 12rem);
    line-height: 1;
    color: #D4D0C8;
    letter-spacing: -0.02em;
    transition: opacity 0.4s ease;
  }

  .artist-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 11px;
    color: #71717a;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    flex-shrink: 0;
    margin-left: 2rem;
  }

  .artist-row:hover .artist-name {
    opacity: 0.2;
  }

  .artist-backdrop {
    position: fixed;
    inset: 0;
    z-index: 1;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    filter: grayscale(0.6);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const backdrop = document.getElementById('artist-backdrop');
    const rows = document.querySelectorAll('.artist-row');
    if (!backdrop) return;

    rows.forEach((row) => {
      row.addEventListener('mouseenter', () => {
        const photo = row.getAttribute('data-photo');
        if (photo) {
          backdrop.style.backgroundImage = `url(${photo})`;
          backdrop.style.opacity = '0.35';
        }
      });

      row.addEventListener('mouseleave', () => {
        backdrop.style.opacity = '0';
      });

      row.addEventListener('click', () => {
        if ((window as any).playClick) (window as any).playClick();
      });
    });
  });
</script>
