---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArtists } from '../../lib/data';

const artists = getArtists();
---

<BaseLayout title="ARTISTS — WILDFLOWER">
  <main class="min-h-screen flex items-center justify-center px-5 md:px-10">
    <div class="artist-row">
      {artists.map((artist) => (
        <a href={`/artists/${artist.slug}`} class="artist-card">
          <div class="artist-photo-box">
            {artist.photo ? (
              <img src={artist.photo} alt={artist.name} class="artist-thumb" />
            ) : (
              <div class="artist-thumb-placeholder"></div>
            )}
          </div>
          <div class="artist-meta">
            <span class="artist-name">{artist.name}</span>
            <span class="artist-tag">{artist.tag}</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .artist-row {
    display: flex;
    gap: 2.5rem;
    justify-content: center;
    align-items: flex-start;
  }

  .artist-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: opacity 0.3s ease;
    width: 160px;
  }

  .artist-card:hover {
    opacity: 0.6;
  }

  .artist-photo-box {
    width: 160px;
    height: 160px;
    overflow: hidden;
    background: #18181b;
    margin-bottom: 0.6rem;
  }

  .artist-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(0.4);
    transition: filter 0.4s ease;
  }

  .artist-card:hover .artist-thumb {
    filter: grayscale(0);
  }

  .artist-thumb-placeholder {
    width: 100%;
    height: 100%;
    background: #18181b;
  }

  .artist-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .artist-name {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 500;
    font-size: 13px;
    color: #E8E4DE;
    letter-spacing: 0.04em;
  }

  .artist-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 10px;
    color: rgba(230, 230, 230, 0.26);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .artist-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      max-width: 300px;
      padding-top: 2rem;
    }

    .artist-card {
      width: 100%;
    }

    .artist-photo-box {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
    }

    .artist-name {
      font-size: 11px;
    }

    .artist-tag {
      font-size: 8px;
    }
  }
</style>
