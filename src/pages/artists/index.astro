---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArtistCard from '../../components/ArtistCard.astro';
import { getCollection } from 'astro:content';

const artists = (await getCollection('artists')).sort(
  (a, b) => (a.data.order || 0) - (b.data.order || 0)
);
---

<BaseLayout title="成員 — WILDFLOWER野花" description="WILDFLOWER野花 label members">
  <div class="min-h-screen pt-12 pb-20 px-6 md:px-12 lg:px-24 max-w-[1400px] mx-auto">
    <!-- Back button: Space Mono, minimal -->
    <a href="/" class="inline-block font-mono text-[10px] tracking-[0.3em] text-wf-light/30 hover:text-wf-light/60 transition-colors duration-500 mb-16 md:mb-24 uppercase" data-clickable>
      ← Back
    </a>

    <!-- Editorial artist stack: massive names, negative space -->
    <div class="space-y-2 md:space-y-4">
      {artists.map((artist) => (
        <ArtistCard
          slug={artist.slug}
          name={artist.data.name}
          tag={artist.data.tag}
          photo={artist.data.photo}
        />
      ))}
    </div>
  </div>
</BaseLayout>
