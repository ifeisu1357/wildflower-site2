---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArtistCard from '../../components/ArtistCard.astro';
import { getCollection } from 'astro:content';

const artists = (await getCollection('artists')).sort(
  (a, b) => (a.data.order || 0) - (b.data.order || 0)
);
---

<BaseLayout title="成員 — WILDFLOWER野花" description="WILDFLOWER野花 label members">
  <div class="min-h-screen pt-16 pb-20 px-4 md:px-8 lg:px-16 max-w-3xl mx-auto">
    <!-- Header -->
    <div class="mb-10">
      <a href="/" class="inline-block font-display text-sm text-wf-light/40 hover:text-wf-light/70 transition-colors duration-300 mb-6" data-clickable>
        ← 返回
      </a>
      <h1 class="font-display text-xl md:text-2xl font-bold text-wf-white">成員</h1>
    </div>

    <!-- Clean vertical list -->
    <div class="space-y-0">
      {artists.map((artist) => (
        <ArtistCard
          slug={artist.slug}
          name={artist.data.name}
          tag={artist.data.tag}
          photo={artist.data.photo}
        />
      ))}
    </div>
  </div>
</BaseLayout>
