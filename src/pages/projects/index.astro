---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const now = Date.now();
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const projectsWithState = projects.map((project) => {
  const hasReleaseDate = !!project.data.releaseDate;
  const releaseTime = hasReleaseDate ? new Date(project.data.releaseDate!).getTime() : 0;
  const isReleased = project.data.published && (!hasReleaseDate || releaseTime <= now);
  return { project, isReleased, hasReleaseDate };
});
---

<BaseLayout title="PROJECTS — WILDFLOWER">
  <main class="min-h-screen pt-24 pb-8">
    <div class="project-grid">
      {projectsWithState.map(({ project, isReleased, hasReleaseDate }) => (
        <div class="project-tile">
          <img
            src={project.data.cover}
            alt={project.data.title}
            class="project-cover"
            loading="lazy"
          />
          {!isReleased && hasReleaseDate && (
            <div class="countdown-overlay">
              <span class="countdown-text" data-target={project.data.releaseDate}></span>
            </div>
          )}
          <div class="hover-overlay">
            <span class="project-title">{project.data.title}</span>
            <span class="project-artist">{project.data.artist}</span>
          </div>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 0;
  }

  @media (min-width: 640px) {
    .project-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .project-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .project-tile {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .project-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hover-overlay {
    position: absolute;
    inset: 0;
    background: rgba(9, 9, 11, 0.88);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .project-tile:hover .hover-overlay {
    opacity: 1;
  }

  .project-title {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 500;
    font-size: 14px;
    color: #D4D0C8;
    letter-spacing: 0.05em;
    margin-bottom: 0.3rem;
  }

  .project-artist {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 11px;
    color: #71717a;
    letter-spacing: 0.08em;
  }

  .countdown-overlay {
    position: absolute;
    inset: 0;
    background: rgba(9, 9, 11, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .countdown-text {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 400;
    font-size: 13px;
    color: #D4D0C8;
    letter-spacing: 0.1em;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const countdowns = document.querySelectorAll('.countdown-text[data-target]');

    function update() {
      const now = Date.now();
      countdowns.forEach((el) => {
        const target = new Date(el.getAttribute('data-target')!).getTime();
        const diff = target - now;

        if (diff <= 0) {
          el.textContent = 'NOW';
          return;
        }

        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);

        el.textContent = `${d}D ${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      });
    }

    update();
    const interval = setInterval(update, 1000);
    document.addEventListener('astro:before-swap', () => clearInterval(interval), { once: true });
  });
</script>
