---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order || 0) - (b.data.order || 0)
);
---

<BaseLayout title="專案 — WILDFLOWER野花" description="WILDFLOWER野花 projects and releases">
  <div class="min-h-screen pt-16 pb-20 px-4 md:px-8 lg:px-16 max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-8 md:mb-12">
      <h1 class="font-display text-lg md:text-xl font-medium text-wf-white mb-1">專案</h1>
      <p class="font-mono text-[10px] tracking-[0.3em] text-wf-light/30 uppercase">Projects</p>
    </div>

    <!-- Grid -->
    <ProjectGrid>
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          artist={project.data.artist}
          cover={project.data.cover}
          type={project.data.type}
          year={project.data.year}
          releaseDate={project.data.releaseDate}
          published={project.data.published}
        />
      ))}
    </ProjectGrid>
  </div>
</BaseLayout>
