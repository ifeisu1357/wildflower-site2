---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const now = Date.now();
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const projectsWithState = projects.map((project) => {
  const hasReleaseDate = !!project.data.releaseDate;
  const releaseTime = hasReleaseDate ? new Date(project.data.releaseDate!).getTime() : 0;
  const isReleased = project.data.published && (!hasReleaseDate || releaseTime <= now);
  return { project, isReleased, hasReleaseDate };
});
---

<BaseLayout title="PROJECTS — WILDFLOWER">
  <main class="min-h-screen flex items-center justify-center px-5 md:px-10 py-24">
    <div class="project-list">
      {projectsWithState.map(({ project, isReleased, hasReleaseDate }) => (
        <div class="project-item">
          <div class="project-tile">
            <img
              src={project.data.cover}
              alt={project.data.title}
              class="project-cover"
              loading="lazy"
            />
            {!isReleased && hasReleaseDate && (
              <div class="countdown-badge">
                <span class="countdown-text" data-target={project.data.releaseDate}></span>
              </div>
            )}
          </div>
          <div class="project-info">
            <span class="project-title">{project.data.title}</span>
            <span class="project-artist">{project.data.artist}</span>
          </div>
        </div>
      ))}

      <!-- Coming Soon placeholder -->
      <div class="project-item">
        <div class="project-tile coming-soon-tile">
          <span class="coming-soon-text">COMING SOON</span>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .project-list {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 700px;
  }

  .project-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .project-tile {
    position: relative;
    width: 200px;
    height: 200px;
    overflow: hidden;
    background: #111113;
  }

  .project-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .project-tile:hover .project-cover {
    opacity: 1;
  }

  .project-info {
    text-align: center;
  }

  .project-title {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 500;
    font-size: 12px;
    color: #E8E4DE;
    letter-spacing: 0.05em;
    display: block;
  }

  .project-artist {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 10px;
    color: #71717a;
    letter-spacing: 0.08em;
    display: block;
    margin-top: 0.15rem;
  }

  .countdown-badge {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(9, 9, 11, 0.85);
    padding: 0.4rem;
    text-align: center;
  }

  .countdown-text {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 400;
    font-size: 10px;
    color: #E8E4DE;
    letter-spacing: 0.1em;
  }

  .coming-soon-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(232, 228, 222, 0.08);
  }

  .coming-soon-text {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 10px;
    color: #71717a;
    letter-spacing: 0.2em;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const countdowns = document.querySelectorAll('.countdown-text[data-target]');

    function update() {
      const now = Date.now();
      countdowns.forEach((el) => {
        const target = new Date(el.getAttribute('data-target')!).getTime();
        const diff = target - now;

        if (diff <= 0) { el.textContent = 'NOW'; return; }

        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);

        el.textContent = `${d}D ${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      });
    }

    update();
    const interval = setInterval(update, 1000);
    document.addEventListener('astro:before-swap', () => clearInterval(interval), { once: true });
  });
</script>
