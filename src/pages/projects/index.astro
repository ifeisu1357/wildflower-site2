---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects } from '../../lib/data';

const now = Date.now();
const projects = getProjects();
const projectsWithState = projects.map((project) => {
  const hasReleaseDate = !!project.releaseDate;
  const releaseTime = hasReleaseDate ? new Date(project.releaseDate!).getTime() : 0;
  const isReleased = project.published && (!hasReleaseDate || releaseTime <= now);
  return { project, isReleased, hasReleaseDate };
});
---

<BaseLayout title="PROJECTS — WILDFLOWER">
  <main class="min-h-screen flex items-center justify-center px-5 md:px-10 pb-24 md:pb-0 pt-4 md:pt-24">
    <div class="project-grid">
      {projectsWithState.map(({ project, isReleased, hasReleaseDate }) => (
        <div class="project-cell" data-title={project.title} data-artist={project.artist} data-year={project.year}>
          <img
            src={project.cover}
            alt={project.title}
            class="project-img"
            loading="lazy"
          />
          <div class="project-overlay">
            <span class="overlay-title">{project.title}</span>
            <span class="overlay-artist">{project.artist}</span>
            {!isReleased && hasReleaseDate && (
              <span class="overlay-countdown" data-target={project.releaseDate}></span>
            )}
          </div>
        </div>
      ))}

      <!-- Coming Soon placeholders to fill grid -->
      <div class="project-cell coming-soon">
        <span class="cs-text">COMING SOON</span>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, 220px);
    gap: 4px;
    max-width: 920px;
    justify-content: center;
  }

  .project-cell {
    position: relative;
    width: 220px;
    height: 220px;
    overflow: hidden;
    background: #18181b;
    cursor: pointer;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(9, 9, 11, 0.82);
    opacity: 0;
    transition: opacity 0.3s ease;
    padding: 0.75rem;
    pointer-events: none;
  }

  .project-cell:hover .project-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  .overlay-title {
    font-family: 'Noto Serif TC', serif;
    font-weight: 700;
    font-size: 16px;
    color: #E8E4DE;
    letter-spacing: 0.04em;
    text-align: center;
    line-height: 1.3;
  }

  .overlay-artist {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 12px;
    color: #71717a;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
  }

  .overlay-countdown {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 400;
    font-size: 12px;
    color: #D4853A;
    letter-spacing: 0.06em;
    margin-top: 0.35rem;
  }

  .coming-soon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cs-text {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 11px;
    color: #3f3f46;
    letter-spacing: 0.15em;
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
      max-width: 340px;
      margin: 0 auto;
    }

    .project-cell {
      width: 100%;
      height: auto;
      aspect-ratio: 1;
    }

    .overlay-title {
      font-size: 12px;
    }

    .overlay-artist,
    .overlay-countdown {
      font-size: 9px;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const countdowns = document.querySelectorAll('.overlay-countdown[data-target]');

    function update() {
      const now = Date.now();
      countdowns.forEach((el) => {
        const target = new Date(el.getAttribute('data-target')!).getTime();
        const diff = target - now;

        if (diff <= 0) { el.textContent = 'OUT NOW'; return; }

        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);

        el.textContent = `${d}D ${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
      });
    }

    update();
    const interval = setInterval(update, 1000);
    document.addEventListener('astro:before-swap', () => clearInterval(interval), { once: true });
  });
</script>
