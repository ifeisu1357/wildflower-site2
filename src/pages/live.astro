  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <a href="/" class="inline-block font-display text-sm text-wf-light/40 hover:text-wf-light/70 transition-colors duration-300 mb-12" data-clickable>
        ← 返回
      </a>
      <h1 class="font-display text-xl md:text-2xl font-bold text-wf-white mb-4">演出</h1>
      <p class="font-display text-sm tracking-[0.3em] text-wf-light/25">COMING SOON</p>
    </div>
  </div>
</BaseLayout>
