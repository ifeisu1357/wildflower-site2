---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="演出 — WILDFLOWER野花" description="WILDFLOWER野花 live shows and events">
  <div class="min-h-screen pt-16 pb-20 px-4 md:px-8 lg:px-16 max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-8 md:mb-12">
      <h1 class="font-display text-lg md:text-xl font-medium text-wf-white mb-1">演出</h1>
      <p class="font-mono text-[10px] tracking-[0.3em] text-wf-light/30 uppercase">Live</p>
    </div>

    <!-- Empty state -->
    <div class="border-t border-wf-mid/20">
      <div class="py-16 text-center">
        <p class="font-mono text-sm tracking-[0.2em] text-wf-light/25">暫無演出</p>
        <p class="font-mono text-[10px] tracking-[0.15em] text-wf-light/15 mt-2">NO UPCOMING SHOWS</p>
      </div>
    </div>
  </div>
</BaseLayout>
