---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLiveEvents } from '../lib/data';

const events = getLiveEvents();
---

<BaseLayout title="LIVE — WILDFLOWER">
  <main class="min-h-screen flex items-center justify-center px-5 md:px-10">
    {events.length > 0 ? (
      <div class="live-list w-full max-w-3xl">
        {events.map((event) => (
          <div class="live-row">
            <span class="live-date">{event.date}</span>
            <span class="live-event">
              {event.event}
              {event.venue && <span class="live-venue"> — {event.venue}</span>}
              {event.city && <span class="live-city">, {event.city}</span>}
            </span>
            {event.ticketUrl && (
              <a href={event.ticketUrl} target="_blank" rel="noopener" class="live-ticket">TICKETS</a>
            )}
          </div>
        ))}
      </div>
    ) : (
      <span class="nothing-scheduled">NOTHING SCHEDULED</span>
    )}
  </main>
</BaseLayout>

<style>
  .live-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .live-row {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(39, 39, 42, 0.4);
  }

  .live-date {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 400;
    font-size: 13px;
    color: #71717a;
    letter-spacing: 0.05em;
    flex-shrink: 0;
    min-width: 7rem;
  }

  .live-event {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 14px;
    color: #D4D0C8;
    flex: 1;
  }

  .live-venue, .live-city {
    color: #71717a;
  }

  .live-ticket {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 400;
    font-size: 10px;
    color: #D4D0C8;
    text-decoration: none;
    letter-spacing: 0.12em;
    opacity: 0.4;
    flex-shrink: 0;
  }

  .live-ticket:hover {
    opacity: 1;
  }

  .nothing-scheduled {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 300;
    font-size: 11px;
    color: #71717a;
    letter-spacing: 0.2em;
  }

  @media (max-width: 640px) {
    .live-row {
      flex-direction: column;
      gap: 0.3rem;
      padding: 0.6rem 0;
    }

    .live-date {
      font-size: 11px;
      min-width: auto;
    }

    .live-event {
      font-size: 12px;
    }
  }
</style>
