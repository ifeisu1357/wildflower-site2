---
import '../styles/global.css';
import Topper from '../components/Topper.astro';
import CustomCursor from '../components/CustomCursor.astro';
import AudioManager from '../components/AudioManager.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
}

const { title = 'WILDFLOWER' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="WILDFLOWER — Independent music label" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <ViewTransitions />
  </head>
  <body>
    <Topper />
    <CustomCursor />
    <AudioManager />
    <slot />
  </body>
</html>
